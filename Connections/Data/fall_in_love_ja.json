{
  "schemaVersion": 1,
  "language": "ja",
  "prompts": [
    { "id": "fil_01", "text": "世界中の誰かをディナーに招待できるとしたら、誰を呼ぶ？", "intensity": "honest", "depth": "warmUp", "order": 1 },
    { "id": "fil_02", "text": "有名になりたいと思う？どんなかたちで？", "intensity": "honest", "depth": "warmUp", "order": 2 },
    { "id": "fil_03", "text": "電話をかける前に、何を言うか頭の中でリハーサルすることはある？なぜ？", "intensity": "honest", "depth": "warmUp", "order": 3 },
    { "id": "fil_04", "text": "完璧な一日って、どんな一日だろう？", "intensity": "honest", "depth": "warmUp", "order": 4 },
    { "id": "fil_05", "text": "最後に歌ったのはいつ？ひとりで、あるいは誰かのそばで", "intensity": "honest", "depth": "warmUp", "order": 5 },
    { "id": "fil_06", "text": "90歳まで生きられるとしたら、心と体のどちらを若く保ちたい？", "intensity": "honest", "depth": "realTalk", "order": 6 },
    { "id": "fil_07", "text": "自分がどのように死ぬか、何となくイメージがある？", "intensity": "honest", "depth": "realTalk", "order": 7 },
    { "id": "fil_08", "text": "ふたりに共通することが三つあるとしたら、何だと思う？", "intensity": "honest", "depth": "realTalk", "order": 8 },
    { "id": "fil_09", "text": "今、いちばん感謝していることは何？", "intensity": "honest", "depth": "realTalk", "order": 9 },
    { "id": "fil_10", "text": "育ち方で変えたいことがあるとしたら、何だろう？", "intensity": "honest", "depth": "realTalk", "order": 10 },
    { "id": "fil_11", "text": "自分のLife Storyを、数分で話してみて", "intensity": "honest", "depth": "realTalk", "order": 11 },
    { "id": "fil_12", "text": "明日目覚めたら新しい能力が身についていたとしたら、何がいい？", "intensity": "honest", "depth": "realTalk", "order": 12 },
    { "id": "fil_13", "text": "未来を知ることができるとしたら、何を知りたい？", "intensity": "unfiltered", "depth": "deepDive", "order": 13 },
    { "id": "fil_14", "text": "ずっとやってみたいと思いながら、まだできていないことは何？", "intensity": "unfiltered", "depth": "deepDive", "order": 14 },
    { "id": "fil_15", "text": "自分がいちばん誇りに思う達成は何？", "intensity": "unfiltered", "depth": "deepDive", "order": 15 },
    { "id": "fil_16", "text": "友情において、いちばん大切にしていることは何？", "intensity": "unfiltered", "depth": "deepDive", "order": 16 },
    { "id": "fil_17", "text": "心に残っている、大切な記憶を一つ教えて", "intensity": "unfiltered", "depth": "deepDive", "order": 17 },
    { "id": "fil_18", "text": "つらかった記憶を一つ、話してみて", "intensity": "unfiltered", "depth": "deepDive", "order": 18 },
    { "id": "fil_19", "text": "残り一年しかないとしたら、今の生き方を変えたいと思う？", "intensity": "unfiltered", "depth": "deepDive", "order": 19 },
    { "id": "fil_20", "text": "友情って、どんなものだと思う？", "intensity": "unfiltered", "depth": "deepDive", "order": 20 },
    { "id": "fil_21", "text": "愛情や深い親しさは、生活の中でどんな役割を果たしている？", "intensity": "unfiltered", "depth": "deepDive", "order": 21 },
    { "id": "fil_22", "text": "相手のことで、感謝していることを一つ伝えて", "intensity": "unfiltered", "depth": "deepDive", "order": 22 },
    { "id": "fil_23", "text": "育った頃の家族は、どんな感じだった？", "intensity": "unfiltered", "depth": "deepDive", "order": 23 },
    { "id": "fil_24", "text": "お母さんとの関係について、どう感じている？", "intensity": "unfiltered", "depth": "deepDive", "order": 24 },
    { "id": "fil_25", "text": "ふたりについて、「ふたりは____」という文を三つ作ってみて", "intensity": "unfiltered", "depth": "deepDive", "order": 25 },
    { "id": "fil_26", "text": "文を完成させて：一緒に____を分かち合える人がいたらいいのに", "intensity": "unfiltered", "depth": "deepDive", "order": 26 },
    { "id": "fil_27", "text": "もし仲良くなるなら、自分のことで知っておいてほしいことがある？", "intensity": "unfiltered", "depth": "deepDive", "order": 27 },
    { "id": "fil_28", "text": "相手のことで、心から感謝していることを教えて", "intensity": "unfiltered", "depth": "deepDive", "order": 28 },
    { "id": "fil_29", "text": "恥ずかしかった思い出を一つ話して", "intensity": "unfiltered", "depth": "deepDive", "order": 29 },
    { "id": "fil_30", "text": "最後に泣いたのはいつ？誰かのそばで、あるいはひとりで", "intensity": "unfiltered", "depth": "deepDive", "order": 30 },
    { "id": "fil_31", "text": "相手のことで、もう好きだと思っていることを一つ伝えて", "intensity": "unfiltered", "depth": "deepDive", "order": 31 },
    { "id": "fil_32", "text": "冗談にできないほど深刻なことって、何だと思う？", "intensity": "unfiltered", "depth": "deepDive", "order": 32 },
    { "id": "fil_33", "text": "今夜死ぬとしたら、言わなかったことを後悔しそうなことは何？", "intensity": "unfiltered", "depth": "deepDive", "order": 33 },
    { "id": "fil_34", "text": "火事になったら何を持ち出す？それはなぜ？", "intensity": "unfiltered", "depth": "deepDive", "order": 34 },
    { "id": "fil_35", "text": "誰かが亡くなったとしたら、いちばん心に響くのは誰の死？それはなぜ？", "intensity": "unfiltered", "depth": "deepDive", "order": 35 },
    { "id": "fil_36", "text": "個人的な悩みを話して、相手に聞いたことをそのまま返してもらって", "intensity": "unfiltered", "depth": "deepDive", "order": 36 }
  ]
}
