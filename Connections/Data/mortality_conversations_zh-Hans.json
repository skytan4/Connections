  "prompts": [
    {
      "id": "mc_unsaidLove_001",
      "text": "有什么爱，你以为别人知道，却也许还没有说得足够明白？",
      "topic": "unsaidLove",
      "order": 1
    },
    {
      "id": "mc_unsaidLove_002",
      "text": "趁还有时间，你最想听谁对你说“我爱你”？",
      "topic": "unsaidLove",
      "order": 2
    },
    {
      "id": "mc_unsaidLove_003",
      "text": "你更多用行动而不是语言表达哪种爱意？",
      "topic": "unsaidLove",
      "order": 3
    },
    {
      "id": "mc_unsaidLove_004",
      "text": "你生命里谁可能需要听见：对你来说，那个人很重要？",
      "topic": "unsaidLove",
      "order": 4
    },
    {
      "id": "mc_unsaidLove_005",
      "text": "哪一种爱最难让你说出口？",
      "topic": "unsaidLove",
      "order": 5
    },
    {
      "id": "mc_unsaidLove_006",
      "text": "你希望家人知道，你曾多么深地爱着他们？",
      "topic": "unsaidLove",
      "order": 6
    },
    {
      "id": "mc_unsaidLove_007",
      "text": "如果只能说一句真心话，你希望亲近的朋友知道什么？",
      "topic": "unsaidLove",
      "order": 7
    },
    {
      "id": "mc_unsaidLove_008",
      "text": "谁曾用一种当时你没有完全明白的方式爱过你？",
      "topic": "unsaidLove",
      "order": 8
    },
    {
      "id": "mc_unsaidLove_009",
      "text": "离开以后，你希望人们记得你爱里的哪一部分？",
      "topic": "unsaidLove",
      "order": 9
    },
    {
      "id": "mc_unsaidLove_010",
      "text": "如果不再等那个完美的开口时机，什么会改变？",
      "topic": "unsaidLove",
      "order": 10
    },
    {
      "id": "mc_gratitudeBeforeTooLate_001",
      "text": "谁用也许自己都不知道的方式，让你的生活轻了一些？",
      "topic": "gratitudeBeforeTooLate",
      "order": 11
    },
    {
      "id": "mc_gratitudeBeforeTooLate_002",
      "text": "哪一种平常的善意，直到现在仍比别人意识到的更有分量？",
      "topic": "gratitudeBeforeTooLate",
      "order": 12
    },
    {
      "id": "mc_gratitudeBeforeTooLate_003",
      "text": "你想感谢谁，曾帮助你成为自己？",
      "topic": "gratitudeBeforeTooLate",
      "order": 13
    },
    {
      "id": "mc_gratitudeBeforeTooLate_004",
      "text": "哪份欠下的感谢，你一直默默放在心里？",
      "topic": "gratitudeBeforeTooLate",
      "order": 14
    },
    {
      "id": "mc_gratitudeBeforeTooLate_005",
      "text": "谁在没有义务的时候，仍然站出来支持你？",
      "topic": "gratitudeBeforeTooLate",
      "order": 15
    },
    {
      "id": "mc_gratitudeBeforeTooLate_006",
      "text": "你想感谢父母、孩子、手足或自己选择的家人什么？",
      "topic": "gratitudeBeforeTooLate",
      "order": 16
    },
    {
      "id": "mc_gratitudeBeforeTooLate_007",
      "text": "哪一个小小的照顾，你希望有人知道你从未忘记？",
      "topic": "gratitudeBeforeTooLate",
      "order": 17
    },
    {
      "id": "mc_gratitudeBeforeTooLate_008",
      "text": "谁用生活的方式教会了你一些关于爱的事？",
      "topic": "gratitudeBeforeTooLate",
      "order": 18
    },
    {
      "id": "mc_gratitudeBeforeTooLate_009",
      "text": "哪份感激如果从未表达，会让你觉得还没有完成？",
      "topic": "gratitudeBeforeTooLate",
      "order": 19
    },
    {
      "id": "mc_gratitudeBeforeTooLate_010",
      "text": "你想留下些什么样的书面感谢？",
      "topic": "gratitudeBeforeTooLate",
      "order": 20
    },
    {
      "id": "mc_repairForgiveness_001",
      "text": "在生命结束前，你希望哪段关系能多一些平静？",
      "topic": "repairForgiveness",
      "order": 21
    },
    {
      "id": "mc_repairForgiveness_002",
      "text": "哪一句道歉，因为太复杂而被你拖延了？",
      "topic": "repairForgiveness",
      "order": 22
    },
    {
      "id": "mc_repairForgiveness_003",
      "text": "你希望自己当初能带着更多体谅去理解谁？",
      "topic": "repairForgiveness",
      "order": 23
    },
    {
      "id": "mc_repairForgiveness_004",
      "text": "哪场旧冲突，如今已经没有过去那么重要？",
      "topic": "repairForgiveness",
      "order": 24
    },
    {
      "id": "mc_repairForgiveness_005",
      "text": "如果无法亲自重逢，原谅是否仍然可能？",
      "topic": "repairForgiveness",
      "order": 25
    },
    {
      "id": "mc_repairForgiveness_006",
      "text": "你还需要原谅自己什么？",
      "topic": "repairForgiveness",
      "order": 26
    },
    {
      "id": "mc_repairForgiveness_007",
      "text": "谁可能还承受着你造成的伤痛，而你还没有真正承认？",
      "topic": "repairForgiveness",
      "order": 27
    },
    {
      "id": "mc_repairForgiveness_008",
      "text": "即使不能修好一切，什么样的修补仍然有意义？",
      "topic": "repairForgiveness",
      "order": 28
    },
    {
      "id": "mc_repairForgiveness_009",
      "text": "哪一种怨，你不想带到生命尽头？",
      "topic": "repairForgiveness",
      "order": 29
    },
    {
      "id": "mc_repairForgiveness_010",
      "text": "如果说出来，哪一个真相可能帮助旧伤开始愈合？",
      "topic": "repairForgiveness",
      "order": 30
    },
    {
      "id": "mc_rememberedHonestly_001",
      "text": "你希望人们记住关于你的什么，不是了不起，只是真实？",
      "topic": "rememberedHonestly",
      "order": 31
    },
    {
      "id": "mc_rememberedHonestly_002",
      "text": "你希望自己的哪一面被带着幽默记住？",
      "topic": "rememberedHonestly",
      "order": 32
    },
    {
      "id": "mc_rememberedHonestly_003",
      "text": "你希望别人用善意理解你的哪个缺点？",
      "topic": "rememberedHonestly",
      "order": 33
    },
    {
      "id": "mc_rememberedHonestly_004",
      "text": "你希望别人说，你最在乎的是什么？",
      "topic": "rememberedHonestly",
      "order": 34
    },
    {
      "id": "mc_rememberedHonestly_005",
      "text": "关于你的哪段故事会显得真实，而不是把你说得完美？",
      "topic": "rememberedHonestly",
      "order": 35
    },
    {
      "id": "mc_rememberedHonestly_006",
      "text": "你希望人们记得，你让别人有过什么感受？",
      "topic": "rememberedHonestly",
      "order": 36
    },
    {
      "id": "mc_rememberedHonestly_007",
      "text": "你最不希望自己的人生被简化成什么？",
      "topic": "rememberedHonestly",
      "order": 37
    },
    {
      "id": "mc_rememberedHonestly_008",
      "text": "你希望人们保留下哪个平凡版本的你？",
      "topic": "rememberedHonestly",
      "order": 38
    },
    {
      "id": "mc_rememberedHonestly_009",
      "text": "被准确记住，而不是被理想化记住，意味着什么？",
      "topic": "rememberedHonestly",
      "order": 39
    },
    {
      "id": "mc_rememberedHonestly_010",
      "text": "你希望有人诚实讲出你人生的哪一部分？",
      "topic": "rememberedHonestly",
      "order": 40
    },
    {
      "id": "mc_legacy_001",
      "text": "你最想留给爱你的人哪一种价值？",
      "topic": "legacy",
      "order": 41
    },
    {
      "id": "mc_legacy_002",
      "text": "你希望哪段人生故事被讲给后来的世代听？",
      "topic": "legacy",
      "order": 42
    },
    {
      "id": "mc_legacy_003",
      "text": "你希望某个传统被保留、改变，或被理解？",
      "topic": "legacy",
      "order": 43
    },
    {
      "id": "mc_legacy_004",
      "text": "你想用自己的话给未来的家人留下什么建议？",
      "topic": "legacy",
      "order": 44
    },
    {
      "id": "mc_legacy_005",
      "text": "哪件物品、食谱、短语或习惯，承载着你故事的一部分？",
      "topic": "legacy",
      "order": 45
    },
    {
      "id": "mc_legacy_006",
      "text": "你希望家里的孩子知道哪些关于自己来处的事？",
      "topic": "legacy",
      "order": 46
    },
    {
      "id": "mc_legacy_007",
      "text": "生活用艰难的方式教会你的哪一课，可能帮助别人？",
      "topic": "legacy",
      "order": 47
    },
    {
      "id": "mc_legacy_008",
      "text": "如果声音可以为以后某个人保存下来，你会录下什么？",
      "topic": "legacy",
      "order": 48
    },
    {
      "id": "mc_legacy_009",
      "text": "你希望朋友把你人生里的什么继续传下去？",
      "topic": "legacy",
      "order": 49
    },
    {
      "id": "mc_legacy_010",
      "text": "什么样的传承感觉是出于爱，而不是做给别人看？",
      "topic": "legacy",
      "order": 50
    },
    {
      "id": "mc_ordinaryMoments_001",
      "text": "如果能再经历一次，你想重温和所爱之人的哪个平凡瞬间？",
      "topic": "ordinaryMoments",
      "order": 51
    },
    {
      "id": "mc_ordinaryMoments_002",
      "text": "人们会想念你身上的哪一个日常习惯？",
      "topic": "ordinaryMoments",
      "order": 52
    },
    {
      "id": "mc_ordinaryMoments_003",
      "text": "哪个地方承载的人生，比表面看起来更多？",
      "topic": "ordinaryMoments",
      "order": 53
    },
    {
      "id": "mc_ordinaryMoments_004",
      "text": "哪次假期或旅行承载着你珍惜的记忆？",
      "topic": "ordinaryMoments",
      "order": 54
    },
    {
      "id": "mc_ordinaryMoments_005",
      "text": "你希望哪一个小小的家庭传统被记住？",
      "topic": "ordinaryMoments",
      "order": 55
    },
    {
      "id": "mc_ordinaryMoments_006",
      "text": "哪一个小小的友情仪式，比外人看到的更有意义？",
      "topic": "ordinaryMoments",
      "order": 56
    },
    {
      "id": "mc_ordinaryMoments_007",
      "text": "后来才发现自己会想念的普通一天，是哪一天？",
      "topic": "ordinaryMoments",
      "order": 57
    },
    {
      "id": "mc_ordinaryMoments_008",
      "text": "日常中的哪种声音、气味或话语，会把某个人带回你心里？",
