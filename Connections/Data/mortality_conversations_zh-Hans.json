      "order": 106
    },
    {
      "id": "mc_childrenMissedFutures_005",
      "text": "你希望孩子听见哪段关于你爱着这个孩子的故事？",
      "topic": "childrenMissedFutures",
      "order": 107
    },
    {
      "id": "mc_childrenMissedFutures_006",
      "text": "你想对孩子说什么，等长大以后会明白？",
      "topic": "childrenMissedFutures",
      "order": 108
    },
    {
      "id": "mc_childrenMissedFutures_007",
      "text": "孩子成长中的哪一部分，你希望自己能从远处引导？",
      "topic": "childrenMissedFutures",
      "order": 109
    },
    {
      "id": "mc_childrenMissedFutures_008",
      "text": "你想给所爱的年轻人留下什么祝福？",
      "topic": "childrenMissedFutures",
      "order": 110
    },
    {
      "id": "mc_childrenMissedFutures_009",
      "text": "关于你的爱，你希望这个孩子永远不要怀疑什么？",
      "topic": "childrenMissedFutures",
      "order": 111
    },
    {
      "id": "mc_childrenMissedFutures_010",
      "text": "你希望孩子未来可以自由拥有哪一种快乐？",
      "topic": "childrenMissedFutures",
      "order": 112
    },
    {
      "id": "mc_deathOfChild_001",
      "text": "一家人怎样才能继续带着爱说出孩子的名字？",
      "topic": "deathOfChild",
      "order": 113
    },
    {
      "id": "mc_deathOfChild_002",
      "text": "孩子的哪段记忆值得被保护，不被死亡遮住？",
      "topic": "deathOfChild",
      "order": 114
    },
    {
      "id": "mc_deathOfChild_003",
      "text": "郑重地记住孩子完整的一生，而不只是那份失去，意味着什么？",
      "topic": "deathOfChild",
      "order": 115
    },
    {
      "id": "mc_deathOfChild_004",
      "text": "哪件物品、故事或仪式，可能帮助家人感觉仍与逝去的孩子相连？",
      "topic": "deathOfChild",
      "order": 116
    },
    {
      "id": "mc_deathOfChild_005",
      "text": "朋友怎样支持父母，而不是试图修好悲伤？",
      "topic": "deathOfChild",
      "order": 117
    },
    {
      "id": "mc_deathOfChild_006",
      "text": "孩子去世后，关于手足，人们需要记得什么？",
      "topic": "deathOfChild",
      "order": 118
    },
    {
      "id": "mc_deathOfChild_007",
      "text": "什么能帮助父母感觉，孩子的一生依然重要？",
      "topic": "deathOfChild",
      "order": 119
    },
    {
      "id": "mc_deathOfChild_008",
      "text": "承载爱的未来改变了以后，爱怎样继续？",
      "topic": "deathOfChild",
      "order": 120
    },
    {
      "id": "mc_deathOfChild_009",
      "text": "关于不会结束的悲伤，人们应该明白什么？",
      "topic": "deathOfChild",
      "order": 121
    },
    {
      "id": "mc_deathOfChild_010",
      "text": "孩子去世后的生日、纪念日和平常日子里，哪种善意可能很重要？",
      "topic": "deathOfChild",
      "order": 122
    },
    {
      "id": "mc_deathOfChild_011",
      "text": "人们想表达同理心时，可以说些什么？",
      "topic": "deathOfChild",
      "order": 123
    },
    {
      "id": "mc_suddenLoss_001",
      "text": "没有机会告别时，什么会觉得还没完成？",
      "topic": "suddenLoss",
      "order": 124
    },
    {
      "id": "mc_suddenLoss_002",
      "text": "突然失去以后，你会一直问哪一个问题？",
      "topic": "suddenLoss",
      "order": 125
    },
    {
      "id": "mc_suddenLoss_003",
      "text": "在那个人最后一个平常的日子里，你希望对方知道什么？",
      "topic": "suddenLoss",
      "order": 126
    },
    {
      "id": "mc_suddenLoss_004",
      "text": "震惊会怎样改变悲伤到来的方式？",
      "topic": "suddenLoss",
      "order": 127
    },
    {
      "id": "mc_suddenLoss_005",
      "text": "即使死亡不是谁的错，一个人仍可能背负哪种愧疚？",
      "topic": "suddenLoss",
      "order": 128
    },
    {
      "id": "mc_suddenLoss_006",
      "text": "如果时间没有给你一个告别，你会创造怎样的告别？",
      "topic": "suddenLoss",
      "order": 129
    },
    {
      "id": "mc_suddenLoss_007",
      "text": "事故或突然死亡之后，脑海会不断重播什么？",
      "topic": "suddenLoss",
      "order": 130
    },
    {
      "id": "mc_suddenLoss_008",
      "text": "当一个人还在努力相信失去是真的，什么支持会有帮助？",
      "topic": "suddenLoss",
      "order": 131
    },
    {
      "id": "mc_suddenLoss_009",
      "text": "当别人都继续往前走后，你希望朋友理解那之后的几个星期是什么样？",
      "topic": "suddenLoss",
      "order": 132
    },
    {
      "id": "mc_suddenLoss_010",
      "text": "什么仪式能承接那些再也没来得及说出口的话？",
      "topic": "suddenLoss",
      "order": 133
    },
    {
      "id": "mc_anticipatoryGrief_001",
      "text": "在人还没有离开之前，已经在为哪些事悲伤？",
      "topic": "anticipatoryGrief",
      "order": 134
    },
    {
      "id": "mc_anticipatoryGrief_002",
      "text": "一边爱着一个人，一边看着对方改变，难在哪里？",
      "topic": "anticipatoryGrief",
      "order": 135
    },
    {
      "id": "mc_anticipatoryGrief_003",
      "text": "当治愈不再是唯一的希望时，希望是什么样子？",
      "topic": "anticipatoryGrief",
      "order": 136
    },
    {
      "id": "mc_anticipatoryGrief_004",
      "text": "当时间显得有限，哪些谈话变得可能？",
      "topic": "anticipatoryGrief",
      "order": 137
    },
    {
      "id": "mc_anticipatoryGrief_005",
      "text": "即使已有提醒，哪些谈话仍然觉得不可能？",
      "topic": "anticipatoryGrief",
      "order": 138
    },
    {
      "id": "mc_anticipatoryGrief_006",
      "text": "慢慢告别意味着什么？",
      "topic": "anticipatoryGrief",
      "order": 139
    },
    {
      "id": "mc_anticipatoryGrief_007",
      "text": "一家人怎样一边制造回忆，一边为失去做准备？",
      "topic": "anticipatoryGrief",
      "order": 140
    },
    {
      "id": "mc_anticipatoryGrief_008",
      "text": "在疾病之外，你努力继续看见那个人的哪一部分？",
      "topic": "anticipatoryGrief",
      "order": 141
    },
    {
      "id": "mc_anticipatoryGrief_009",
      "text": "一边还被需要，一边已经在悲伤，痛在哪里？",
      "topic": "anticipatoryGrief",
      "order": 142
    },
    {
      "id": "mc_anticipatoryGrief_010",
      "text": "漫长的告别里，可能存在怎样小小的慈悲？",
      "topic": "anticipatoryGrief",
      "order": 143
    },
    {
      "id": "mc_friendsStayDisappear_001",
      "text": "如果生活变得很艰难，你觉得谁会出现？",
      "topic": "friendsStayDisappear",
      "order": 144
    },
    {
      "id": "mc_friendsStayDisappear_002",
      "text": "当有人正在走向死亡或正在悲伤，是什么让人们消失？",
      "topic": "friendsStayDisappear",
      "order": 145
    },
    {
      "id": "mc_friendsStayDisappear_003",
      "text": "什么样的朋友能和痛苦坐在一起，而不急着逃开？",
      "topic": "friendsStayDisappear",
      "order": 146
    },
    {
      "id": "mc_friendsStayDisappear_004",
      "text": "即使你常常说不，你仍希望朋友继续邀请你参与什么？",
      "topic": "friendsStayDisappear",
      "order": 147
    },
    {
      "id": "mc_friendsStayDisappear_005",
      "text": "在让别人不自在的时期，谁仍然留在你身边？",
      "topic": "friendsStayDisappear",
      "order": 148
    },
    {
      "id": "mc_friendsStayDisappear_006",
      "text": "朋友给出的哪种支持，会既实际又有爱？",
      "topic": "friendsStayDisappear",
      "order": 149
    },
    {
      "id": "mc_friendsStayDisappear_007",
      "text": "你想对害怕说错话的朋友说什么？",
      "topic": "friendsStayDisappear",
      "order": 150
    },
    {
      "id": "mc_friendsStayDisappear_008",
      "text": "当一个人的生活已经改变，继续做朋友意味着什么？",
      "topic": "friendsStayDisappear",
      "order": 151
    },
    {
      "id": "mc_friendsStayDisappear_009",
      "text": "什么样的问候是真实的，而不是做样子？",
      "topic": "friendsStayDisappear",
      "order": 152
    },
    {
      "id": "mc_friendsStayDisappear_010",
      "text": "如果你不能在那里，你希望谁陪在家人身边？",
      "topic": "friendsStayDisappear",
      "order": 153
    },
    {
      "id": "mc_caregivingLove_001",
      "text": "哪一种照顾对你来说像爱？",
      "topic": "caregivingLove",
      "order": 154
    },
    {
      "id": "mc_caregivingLove_002",
      "text": "照顾一个正在衰退的人，什么地方美，什么地方累？",
      "topic": "caregivingLove",
      "order": 155
    },
    {
      "id": "mc_caregivingLove_003",
      "text": "照顾者可能羞于承认哪种怨气？",
      "topic": "caregivingLove",
      "order": 156
    },
    {
      "id": "mc_caregivingLove_004",
      "text": "当付出不断重复又无人看见，忠诚是什么样子？",
      "topic": "caregivingLove",
      "order": 157
    },
    {
      "id": "mc_caregivingLove_005",
      "text": "一个人怎样接受照顾，而不觉得自己只是病人？",
      "topic": "caregivingLove",
      "order": 158
    },
    {
      "id": "mc_caregivingLove_006",
      "text": "你想对曾为照顾你付出很大代价的人说什么？",
      "topic": "caregivingLove",
      "order": 159
    },
    {
      "id": "mc_caregivingLove_007",
      "text": "照顾中的哪一部分会永远改变一段关系？",
      "topic": "caregivingLove",
      "order": 160
    },
    {
      "id": "mc_caregivingLove_008",
      "text": "照顾者需要被允许感受什么？",
      "topic": "caregivingLove",
      "order": 161
    },
    {
      "id": "mc_caregivingLove_009",
      "text": "什么能帮助一家人更诚实地分担照顾？",
      "topic": "caregivingLove",
      "order": 162
    },
    {
      "id": "mc_caregivingLove_010",
      "text": "最艰难的实际事务里，可能有什么温柔？",
      "topic": "caregivingLove",
      "order": 163
    },
    {
      "id": "mc_autonomyControl_001",
      "text": "在别人不得不替你决定之前，你想自己做哪个决定？",
      "topic": "autonomyControl",
      "order": 164
    },
    {
      "id": "mc_autonomyControl_002",
      "text": "如果你不能说话，你信任谁替你发声？",
      "topic": "autonomyControl",
      "order": 165
    },
    {
      "id": "mc_autonomyControl_003",
      "text": "你希望那个人理解你的价值观中什么？",
      "topic": "autonomyControl",
      "order": 166
    },
    {
      "id": "mc_autonomyControl_004",
      "text": "如果可以选择，你希望在哪里接受照顾？",
      "topic": "autonomyControl",
      "order": 167
    },
    {
      "id": "mc_autonomyControl_005",
      "text": "什么能让医疗决定感觉符合你的为人？",
      "topic": "autonomyControl",
      "order": 168
    },
    {
      "id": "mc_autonomyControl_006",
      "text": "如果一种治疗只是延长痛苦，你希望人们质疑哪种治疗？",
      "topic": "autonomyControl",
      "order": 169
    },
    {
      "id": "mc_autonomyControl_007",
      "text": "哪种安慰比掌控更重要？",
      "topic": "autonomyControl",
      "order": 170
    },
    {
      "id": "mc_autonomyControl_008",
      "text": "临近生命尽头时，哪条个人边界仍然重要？",
      "topic": "autonomyControl",
      "order": 171
    },
    {
      "id": "mc_autonomyControl_009",
      "text": "你想把什么写下来，让家人不必猜？",
      "topic": "autonomyControl",
      "order": 172
    },
    {
      "id": "mc_autonomyControl_010",
      "text": "在危机里，你希望爱和选择怎样一起发挥作用？",
      "topic": "autonomyControl",
      "order": 173
    },
    {
      "id": "mc_spiritualPeaceMeaning_001",
      "text": "什么帮助你感到自己的人生有意义？",
      "topic": "spiritualPeaceMeaning",
      "order": 174
    },
    {
      "id": "mc_spiritualPeaceMeaning_002",
      "text": "想到死亡时，哪个关于灵性的问题会变得更迫切？",
      "topic": "spiritualPeaceMeaning",
      "order": 175
    },
    {
      "id": "mc_spiritualPeaceMeaning_003",
      "text": "你希望死后什么是真的？",
      "topic": "spiritualPeaceMeaning",
      "order": 176
    },
    {
      "id": "mc_spiritualPeaceMeaning_004",
      "text": "在哪里你最接近平静？",
      "topic": "spiritualPeaceMeaning",
      "order": 177
    },
    {
      "id": "mc_spiritualPeaceMeaning_005",
      "text": "哪一种信念曾带你穿过恐惧？",
      "topic": "spiritualPeaceMeaning",
      "order": 178
    },
    {
      "id": "mc_spiritualPeaceMeaning_006",
      "text": "哪一个疑问，你希望可以不被评判地谈起？",
      "topic": "spiritualPeaceMeaning",
      "order": 179
    },
    {
      "id": "mc_spiritualPeaceMeaning_007",
      "text": "什么会让你觉得这一生已经足够完整？",
      "topic": "spiritualPeaceMeaning",
      "order": 180
    },
    {
      "id": "mc_spiritualPeaceMeaning_008",
      "text": "自然、信仰、仪式或沉默中的哪一部分安慰你？",
      "topic": "spiritualPeaceMeaning",
      "order": 181
    },
    {
      "id": "mc_spiritualPeaceMeaning_009",
      "text": "哪个谜，你愿意让它没有答案？",
      "topic": "spiritualPeaceMeaning",
      "order": 182
    },
    {
      "id": "mc_spiritualPeaceMeaning_010",
      "text": "在最后之前，你想给予或接受什么祝福？",
      "topic": "spiritualPeaceMeaning",
      "order": 183
    },
    {
      "id": "mc_regret_001",
      "text": "如果能带着现在知道的一切重来，你会重新看待哪个选择？",
      "topic": "regret",
      "order": 184
    },
    {
      "id": "mc_regret_002",
      "text": "你花了太多力气证明什么？",
      "topic": "regret",
      "order": 185
    },
    {
      "id": "mc_regret_003",
      "text": "恐惧让你没能说、没能试、没能改变什么？",
      "topic": "regret",
      "order": 186
    },
    {
      "id": "mc_regret_004",
      "text": "哪段关系被你忽略得比原本打算的更久？",
      "topic": "regret",
      "order": 187
    },
    {
      "id": "mc_regret_005",
      "text": "如果没有为它留出时间，你会后悔什么？",
      "topic": "regret",
      "order": 188
    },
    {
      "id": "mc_regret_006",
      "text": "哪一种成功到最后可能显得空洞？",
      "topic": "regret",
      "order": 189
    },
    {
      "id": "mc_regret_007",
      "text": "你把什么一再推迟，好像时间一定会有？",
      "topic": "regret",
      "order": 190
    },
    {
      "id": "mc_regret_008",
      "text": "如果时间比预想的更短，你会原谅自己什么？",
      "topic": "regret",
      "order": 191
    },
    {
      "id": "mc_regret_009",
      "text": "哪个旧梦仍在请求你以某种小方式尊重它？",
      "topic": "regret",
      "order": 192
    },
    {
      "id": "mc_regret_010",
      "text": "你想停止假装什么并不重要？",
      "topic": "regret",
      "order": 193
    },
    {
      "id": "mc_identityBeyondIllness_001",
      "text": "除了发生在你身上的事，你希望人们记得关于你的什么？",
      "topic": "identityBeyondIllness",
      "order": 194
    },
    {
      "id": "mc_identityBeyondIllness_002",
      "text": "当疾病、悲伤或照顾改变生活，一个人怎样仍然保持自己？",
      "topic": "identityBeyondIllness",
      "order": 195
    },
    {
      "id": "mc_identityBeyondIllness_003",
      "text": "艰难时期里，你希望自己性格的哪一部分被保护？",
      "topic": "identityBeyondIllness",
      "order": 196
    },
    {
      "id": "mc_identityBeyondIllness_004",
      "text": "当人们只把某个人看作病人，会错过什么？",
      "topic": "identityBeyondIllness",
      "order": 197
    },
    {
      "id": "mc_identityBeyondIllness_005",
      "text": "当生活不正常时，什么能帮助你感觉正常一点？",
      "topic": "identityBeyondIllness",
      "order": 198
    },
    {
      "id": "mc_identityBeyondIllness_006",
      "text": "哪个名字、角色或身份，你不希望被失去抹掉？",
      "topic": "identityBeyondIllness",
      "order": 199
    },
    {
      "id": "mc_identityBeyondIllness_007",
      "text": "在痛苦中，你仍希望自己被允许拥有哪种快乐？",
      "topic": "identityBeyondIllness",
      "order": 200
    },
    {
      "id": "mc_identityBeyondIllness_008",
      "text": "关于你自己的哪段故事，比你的痛更大？",
      "topic": "identityBeyondIllness",
      "order": 201
    },
    {
      "id": "mc_identityBeyondIllness_009",
      "text": "如果身体或心智改变，你希望人们怎样和你说话？",
      "topic": "identityBeyondIllness",
      "order": 202
    },
    {
      "id": "mc_identityBeyondIllness_010",
      "text": "到最后，你希望自己的哪一部分仍然显露出来？",
      "topic": "identityBeyondIllness",
      "order": 203
    },
    {
      "id": "mc_familyConflict_001",
      "text": "在疾病或失去的压力下，家庭里的哪种分歧可能变得更尖锐？",
      "topic": "familyConflict",
      "order": 204
    },
    {
      "id": "mc_familyConflict_002",
      "text": "家里谁处理艰难真相的方式与你不同？",
      "topic": "familyConflict",
      "order": 205
    },
    {
      "id": "mc_familyConflict_003",
      "text": "什么能帮助一家人做决定，而不彼此攻击？",
      "topic": "familyConflict",
      "order": 206
    },
    {
      "id": "mc_familyConflict_004",
      "text": "当所有人都害怕时，哪道旧伤可能重新浮现？",
      "topic": "familyConflict",
      "order": 207
    },
    {
      "id": "mc_familyConflict_005",
      "text": "否认保护了什么，又付出了什么代价？",
      "topic": "familyConflict",
      "order": 208
    },
    {
      "id": "mc_familyConflict_006",
      "text": "当人们对照顾有分歧时，爱怎样仍然在场？",
      "topic": "familyConflict",
      "order": 209
    },
    {
      "id": "mc_familyConflict_007",
      "text": "如果不早点讨论，哪件实际事务可能变得很情绪化？",
      "topic": "familyConflict",
      "order": 210
    },
    {
      "id": "mc_familyConflict_008",
      "text": "在家人必须作出选择之前，你希望他们知道你的哪些愿望？",
      "topic": "familyConflict",
      "order": 211
    },
    {
      "id": "mc_familyConflict_009",
      "text": "危机中，你不希望哪种模式被重复？",
      "topic": "familyConflict",
      "order": 212
    },
    {
      "id": "mc_familyConflict_010",
      "text": "如果大家无法达成一致，平静会是什么样？",
      "topic": "familyConflict",
      "order": 213
    },
    {
      "id": "mc_familyConflict_011",
      "text": "如果分配你的物品变得情绪化，你希望家人记住什么？",
      "topic": "familyConflict",
      "order": 214
    },
    {
      "id": "mc_ritualsAnniversaries_001",
      "text": "离开以后，你希望人们温柔地记得哪一个纪念日？",
      "topic": "ritualsAnniversaries",
      "order": 215
    },
    {
      "id": "mc_ritualsAnniversaries_002",
      "text": "有人去世后，什么仪式能帮助爱继续？",
      "topic": "ritualsAnniversaries",
      "order": 216
    },
    {
      "id": "mc_ritualsAnniversaries_003",
      "text": "离开以后的生日，你希望人们做什么？",
      "topic": "ritualsAnniversaries",
      "order": 217
    },
    {
      "id": "mc_ritualsAnniversaries_004",
      "text": "什么地方适合用来怀念一个人？",
      "topic": "ritualsAnniversaries",
      "order": 218
    },
    {
      "id": "mc_ritualsAnniversaries_005",
      "text": "哪首歌、哪顿饭、哪支蜡烛、哪段祈祷或传统，可以承载记忆？",
      "topic": "ritualsAnniversaries",
      "order": 219
    },
    {
      "id": "mc_ritualsAnniversaries_006",
      "text": "失去的纪念日里，朋友应该怎样出现？",
      "topic": "ritualsAnniversaries",
      "order": 220
    },
    {
      "id": "mc_ritualsAnniversaries_007",
      "text": "让一个人的记忆继续活着，对你意味着什么？",
      "topic": "ritualsAnniversaries",
      "order": 221
    },
    {
      "id": "mc_ritualsAnniversaries_008",
      "text": "你想在需要它之前，先开始哪一个家庭仪式？",
      "topic": "ritualsAnniversaries",
      "order": 222
    },
    {
      "id": "mc_ritualsAnniversaries_009",
      "text": "什么能让纪念更贴近这个人，而不是只显得正式？",
      "topic": "ritualsAnniversaries",
      "order": 223
    },
    {
      "id": "mc_ritualsAnniversaries_010",
      "text": "失去以后，哪个平常的年度时刻可能变得神圣？",
      "topic": "ritualsAnniversaries",
      "order": 224
    },
    {
      "id": "mc_comfort_001",
      "text": "当什么都无法解决时，什么能安慰你？",
      "topic": "comfort",
      "order": 225
    },
    {
      "id": "mc_comfort_002",
      "text": "什么样的沉默感觉像支持，而不是空白？",
      "topic": "comfort",
      "order": 226
    },
    {
      "id": "mc_comfort_003",
      "text": "在恐惧或悲伤里，哪些话能让你感觉没那么孤单？",
      "topic": "comfort",
      "order": 227
    },
    {
      "id": "mc_comfort_004",
      "text": "哪些话不会有帮助，即使本意是好的？",
      "topic": "comfort",
      "order": 228
    },
    {
      "id": "mc_comfort_005",
      "text": "如果有的话，哪种身体上的安抚能让你感到安全？",
      "topic": "comfort",
      "order": 229
    },
    {
      "id": "mc_comfort_006",
      "text": "害怕的时候，你希望身边有什么熟悉的东西？",
      "topic": "comfort",
      "order": 230
    },
    {
      "id": "mc_comfort_007",
      "text": "艰难时期里，哪种幽默仍然合适？",
      "topic": "comfort",
      "order": 231
    },
    {
      "id": "mc_comfort_008",
      "text": "允许一个人原原本本地感受自己的感受，意味着什么？",
      "topic": "comfort",
      "order": 232
    },
    {
      "id": "mc_comfort_009",
      "text": "谁知道怎样安慰你，却不接管一切？",
      "topic": "comfort",
      "order": 233
    },
    {
      "id": "mc_comfort_010",
      "text": "如果安慰是诚实而简单的，它会是什么样？",
      "topic": "comfort",
      "order": 234
    },
    {
      "id": "mc_comfort_011",
      "text": "睡不着的时候，你希望能够联系某个人吗？",
      "topic": "comfort",
      "order": 235
    },
    {
      "id": "mc_lastConversation_001",
      "text": "如果只有最后一次谈话，你希望和谁谈？",
      "topic": "lastConversation",
      "order": 236
    },
    {
      "id": "mc_lastConversation_002",
      "text": "在告别感觉完整之前，什么需要被说出来？",
      "topic": "lastConversation",
      "order": 237
    },
    {
      "id": "mc_lastConversation_003",
      "text": "你希望某个人不要再担心什么？",
      "topic": "lastConversation",
      "order": 238
    },
    {
      "id": "mc_lastConversation_004",
      "text": "你想给出什么祝福？",
      "topic": "lastConversation",
      "order": 239
    },
    {
      "id": "mc_lastConversation_005",
      "text": "趁还有时间，你想问什么问题？",
      "topic": "lastConversation",
      "order": 240
    },
    {
      "id": "mc_lastConversation_006",
      "text": "你希望哪个真相被温柔而清楚地说出来，又需要让谁听见？",
      "topic": "lastConversation",
      "order": 241
    },
    {
      "id": "mc_lastConversation_007",
      "text": "你想一起重温哪段记忆？",
      "topic": "lastConversation",
      "order": 242
    },
    {
      "id": "mc_lastConversation_008",
      "text": "最后一次谈话里，哪句道歉、感谢或让人安心的话应该在场？",
      "topic": "lastConversation",
      "order": 243
    },
    {
      "id": "mc_lastConversation_009",
      "text": "你希望最后的语气是什么：平静、诚实、好笑、温柔，还是别的？",
      "topic": "lastConversation",
      "order": 244
    },
    {
      "id": "mc_lastConversation_010",
      "text": "如果没有足够时间把一切都说完，什么仍然能带来安慰？",
      "topic": "lastConversation",
      "order": 245
    },
    {
      "id": "mc_mortalityClarity_001",
      "text": "当你记得生命有限，什么变得更重要？",
      "topic": "mortalityClarity",
      "order": 246
    },
    {
      "id": "mc_mortalityClarity_002",
      "text": "什么已经没有你过去以为的那么重要？",
      "topic": "mortalityClarity",
      "order": 247
    },
    {
      "id": "mc_mortalityClarity_003",
      "text": "如果你相信时间并不是理所当然的，你会改变什么？",
      "topic": "mortalityClarity",
      "order": 248
    },
    {
      "id": "mc_mortalityClarity_004",
      "text": "你会和谁多花一些平凡的时间？",
      "topic": "mortalityClarity",
      "order": 249
    },
    {
      "id": "mc_mortalityClarity_005",
      "text": "面对死亡这件事，需要你拿出哪一种勇气？",
      "topic": "mortalityClarity",
      "order": 250
    },
    {
      "id": "mc_mortalityClarity_006",
      "text": "如果人生比预想中更早结束，什么样的生活仍会让你觉得真实？",
      "topic": "mortalityClarity",
      "order": 251
    },
    {
      "id": "mc_mortalityClarity_007",
      "text": "你会停止等待去享受什么？",
      "topic": "mortalityClarity",
      "order": 252
    },
    {
      "id": "mc_mortalityClarity_008",
      "text": "你会更用心对待哪段关系？",
      "topic": "mortalityClarity",
      "order": 253
    },
    {
      "id": "mc_mortalityClarity_009",
      "text": "关于优先顺序，哪个真相很难再忽视？",
      "topic": "mortalityClarity",
      "order": 254
    },
    {
      "id": "mc_mortalityClarity_010",
      "text": "思考死亡教会你，今天该怎样活？",
      "topic": "mortalityClarity",
      "order": 255
    }
  ]
}
