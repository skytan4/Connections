{
  "sourceLanguage": "en",
  "strings": {
    "paywall.general.body": {
      "comment": "Body text on the general paywall screen explaining the full unlock.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get full access to Share Experiences and every premium conversation tool in Deeper Conversations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accede por completo a Experiencias compartidas y a todas las herramientas premium de conversación de Deeper Conversations."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzyskaj pełny dostęp do Dziel się doświadczeniami i wszystkich narzędzi premium do rozmów w Deeper Conversations."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte vollen Zugriff auf Erfahrungen teilen und alle Premium-Gesprächstools in Deeper Conversations."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez aux Expériences partagées et à tous les outils de conversation premium de Deeper Conversations."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenha acesso completo a Experiências compartilhadas e a todas as ferramentas premium de conversa do Deeper Conversations."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krijg volledige toegang tot Ervaringen delen en elke premium gesprekstool in Deeper Conversations."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "体験をシェアと、Deeper Conversationsのすべてのプレミアム会話ツールを利用できます。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottieni l'accesso completo a Esperienze condivise e a tutti gli strumenti di conversazione premium di Deeper Conversations."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Få full tillgång till Dela upplevelser och alla premiumverktyg för samtal i Deeper Conversations."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Få fuld adgang til Del oplevelser og alle premium-samtaleværktøjer i Deeper Conversations."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Få full tilgang til Del opplevelser og alle premium-samtaleverktøyene i Deeper Conversations."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat täyden pääsyn Jaa kokemuksia -sisältöön ja kaikkiin Deeper Conversationsin premium-keskustelutyökaluihin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完整使用 分享体验 以及 Deeper Conversations 中的所有高级对话工具。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получите полный доступ к Поделиться опытом и всем премиум-инструментам для разговоров в Deeper Conversations."
          }
        }
      }
    },
    "paywall.general.bullet1": {
      "comment": "First feature bullet on the general paywall screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share Experiences for guided, meaningful moments together"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Experiencias compartidas para momentos guiados y significativos juntos"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dziel się doświadczeniami podczas prowadzonych, znaczących chwil razem"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfahrungen teilen für angeleitete, bedeutungsvolle Momente miteinander"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Expériences partagées pour vivre ensemble des moments guidés et porteurs de sens"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Experiências compartilhadas para momentos guiados e significativos juntos"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ervaringen delen voor begeleide, betekenisvolle momenten samen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一緒に意味のある時間を過ごすためのガイド付き体験シェア"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esperienze condivise per momenti guidati e significativi insieme"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dela upplevelser för guidade, meningsfulla stunder tillsammans"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Del oplevelser til guidede, meningsfulde øjeblikke sammen"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Del opplevelser for guidede, meningsfulle øyeblikk sammen"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jaa kokemuksia ohjattuihin ja merkityksellisiin yhteisiin hetkiin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分享体验，帮助你们一起进行有引导、有意义的互动"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поделиться опытом для совместных, осмысленных моментов с подсказками"
          }
        }
      }
    },
    "paywall.general.bullet2": {
      "comment": "Second feature bullet on the general paywall screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History prompts to capture stories, memories, and personal milestones"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompts de Historia de vida para conservar historias, recuerdos e hitos personales"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podpowiedzi Life History do zachowywania historii, wspomnień i osobistych kamieni milowych"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History-Impulse, um Geschichten, Erinnerungen und persönliche Meilensteine festzuhalten"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompts Life History pour recueillir des histoires, des souvenirs et des moments importants"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompts de Life History para registrar histórias, lembranças e marcos pessoais"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History-prompts om verhalen, herinneringen en persoonlijke mijlpalen vast te leggen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "思い出、物語、人生の節目を残すためのLife Historyプロンプト"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompt Life History per raccogliere storie, ricordi e traguardi personali"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History-prompts för att fånga berättelser, minnen och personliga milstolpar"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History-prompts til at indfange historier, minder og personlige milepæle"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History-ledetekster for å ta vare på historier, minner og personlige milepæler"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History -kehotteet tarinoiden, muistojen ja henkilökohtaisten merkkipaalujen tallentamiseen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Life History 提示，用于记录故事、回忆和人生的重要节点"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подсказки Life History, чтобы сохранять истории, воспоминания и важные личные этапы"
          }
        }
      }
    },
    "paywall.general.bullet3": {
