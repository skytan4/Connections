          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Set di domande Senza filtri per Coppie, Famiglia e Amici"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ofiltrerade frågeset för Par, Familj och Vänner"
