    "paywall.purchase.tagline": {
      "comment": "Fallback tagline shown below the primary purchase button if StoreKit price has not loaded.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-time purchase. Lifetime access. No subscription."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra única. Acceso de por vida. Sin suscripción."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorazowy zakup. Dostęp dożywotni. Bez subskrypcji."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmaliger Kauf. Lebenslanger Zugriff. Kein Abo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Achat unique. Accès à vie. Sans abonnement."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra única. Acesso vitalício. Sem assinatura."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eenmalige aankoop. Levenslange toegang. Geen abonnement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一回限りの購入。生涯アクセス。サブスクリプションではありません。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Acquisto unico. Accesso a vita. Nessun abbonamento."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Engångsköp. Livstidsåtkomst. Ingen prenumeration."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Engangskøb. Livstidsadgang. Intet abonnement."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Engangskjøp. Livstidstilgang. Ingen abonnement."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kertaostos. Elinikäinen käyttöoikeus. Ei tilausta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性购买。终身访问。无需订阅。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разовая покупка. Пожизненный доступ. Без подписки."
          }
        }
      }
    },
    "paywall.error.productUnavailable": {
      "comment": "Shown when the StoreKit product fails to load (network issue, App Store Connect misconfig, etc.). Apple guideline: actionable, mentions Restore as backup.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full Access isn't available right now. Please check your connection and try again, or use Restore Purchases if you've already bought it."
          }
        }
      }
    },
    "paywall.error.purchaseFailed": {
      "comment": "Shown when product.purchase() throws (network, payment method failure, etc.). Apple guideline: reassure no charge, offer retry + restore.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your purchase couldn't be completed. No charge was made. Please try again, or use Restore Purchases if you've already bought it."
          }
        }
      }
    },
    "paywall.error.verificationFailed": {
      "comment": "Shown when StoreKit transaction verification fails cryptographically. Apple guideline: actionable, never a dead-end \"contact support\".",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't verify your purchase with the App Store. Please try again. If you were charged, use Restore Purchases."
          }
        }
      }
    },
    "paywall.error.restoreFailed": {
      "comment": "Shown when AppStore.sync() throws during Restore Purchases. Apple guideline: short, actionable, no raw error codes.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore failed. Please check your connection and try again."
          }
        }
      }
    },
    "paywall.info.nothingToRestore": {
      "comment": "Informational (not an error) — shown when Restore Purchases succeeds but no entitlement exists for this Apple ID. Apple guideline: every tap needs visible, actionable feedback.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No previous purchases were found for this Apple ID."
          }
        }
      }
    },
    "paywall.error.productUnavailable": {
