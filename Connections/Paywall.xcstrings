    "paywall.general.bullet5": {
      "comment": "Benefit-focused feature bullet on the general paywall screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock 1,725 premium prompts and follow-ups, for 2,802 total"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea 1,725 prompts y seguimientos premium, para un total de 2,802"
