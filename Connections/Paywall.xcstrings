    "paywall.lifeStory.body": {
      "comment": "Body text on the Life Story paywall screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock the full app and get Life Story too: a guided way to ask parents, grandparents, and loved ones about their memories, stories, and legacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea la app completa y también recibe Life Story: una forma guiada de preguntar a padres, abuelos y seres queridos sobre sus recuerdos, historias y legado."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj całą aplikację i otrzymaj także Life Story: prowadzony sposób pytania rodziców, dziadków i bliskich o wspomnienia, historie i dziedzictwo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte die vollständige App frei und erhalte auch Life Story: eine geführte Möglichkeit, Eltern, Großeltern und nahestehende Menschen nach Erinnerungen, Geschichten und Vermächtnis zu fragen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloque l’app complète et obtiens aussi Life Story : une façon guidée d’interroger parents, grands-parents et proches sur leurs souvenirs, leurs histoires et ce qu’ils souhaitent transmettre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie o app completo e receba Life Story também: uma forma guiada de perguntar a pais, avós e pessoas queridas sobre memórias, histórias e legado."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel de volledige app en krijg Life Story erbij: een begeleide manier om ouders, grootouders en dierbaren te vragen naar hun herinneringen, verhalen en nalatenschap."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フルアプリをアンロックすると、Life Story も使えます。親、祖父母、大切な人に、思い出や物語、受け継ぎたいものについて聞くためのガイド付き体験です。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca l’app completa e ottieni anche Life Story: un modo guidato per chiedere a genitori, nonni e persone care dei loro ricordi, delle loro storie e della loro eredità."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp hela appen och få Life Story också: ett guidat sätt att fråga föräldrar, far- och morföräldrar och närstående om deras minnen, berättelser och arv."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås op for hele appen og få også Life Story: en guidet måde at spørge forældre, bedsteforældre og nære mennesker om deres minder, historier og arv."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås opp hele appen og få Life Story også: en guidet måte å spørre foreldre, besteforeldre og nære personer om minnene, historiene og arven deres."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa koko sovellus ja saat myös Life Storyn: ohjatun tavan kysyä vanhemmilta, isovanhemmilta ja läheisiltä heidän muistoistaan, tarinoistaan ja perinnöstään."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解锁完整应用，也会获得 Life Story：用引导式方式向父母、祖父母和所爱的人询问他们的回忆、故事和传承。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открой полную версию приложения и получи Life Story: проводимый формат для вопросов родителям, бабушкам, дедушкам и близким об их воспоминаниях, историях и наследии."
          }
        }
      }
    },
