        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ufiltrerte spørsmålssett for Par, Familie og Venner"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suodattamattomat kysymyssarjat pareille, perheelle ja ystäville"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "面向情侣、家人和朋友的无滤镜问题套组"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наборы вопросов без фильтров для пар, семьи и друзей"
          }
        }
      }
