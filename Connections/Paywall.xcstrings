        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca 1.725 prompt e domande di approfondimento premium, per un totale di 2.802"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp 1 725 premium-promptar och uppföljningsfrågor, totalt 2 802"
