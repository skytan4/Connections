        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa 1 725 premium-kysymystä ja jatkokysymystä, yhteensä 2 802"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解锁 1,725 个高级问题和跟进问题，共计 2,802 个"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте 1 725 премиум-вопросов и уточнений, всего 2 802"
          }
        }
      }
    },
    "paywall.general.footer": {
      "comment": "Footer text below the feature list on the general paywall screen. Markdown bold markers around numbers are intentional.",
      "extractionState": "manual",
