        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vend tilbage til favoritter, når du vil have en anden slags session"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gå tilbake til favoritter når du vil ha en annen type økt"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palaa suosikkeihin, kun haluat erilaisen istunnon"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "想换一种对话体验时，回顾你的收藏"
          }
