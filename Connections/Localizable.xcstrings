    "lifeStoryIntro.howSheet.bullet1": {
      "comment": "First bullet point in the How It Works sheet describing question count and chapters.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "50 questions organized across 9 life chapters — from childhood to legacy"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "50 preguntas organizadas en 9 capítulos de vida — desde la infancia hasta el legado"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "50 pytań ułożonych w 9 rozdziałach życia — od dzieciństwa po dziedzictwo"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "50 Fragen in 9 Lebenskapitel gegliedert — von der Kindheit bis zum Vermächtnis"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "50 questions réparties sur 9 chapitres de vie — de l'enfance à l'héritage"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "50 perguntas organizadas em 9 capítulos de vida — da infância ao legado"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet2": {
      "comment": "Second bullet point in the How It Works sheet about follow-up questions.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each question comes with two follow-ups to help the conversation go deeper naturally"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada pregunta incluye dos seguimientos para ayudar a que la conversación fluya más profundamente de manera natural"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każde pytanie ma dwa pytania uzupełniające, które pomagają rozmowie pójść głębiej"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Frage hat zwei Folgefragen, die das Gespräch ganz natürlich in die Tiefe führen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque question est accompagnée de deux relances pour approfondir la conversation naturellement"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada pergunta vem acompanhada de dois desdobramentos para ajudar a conversa a ir mais fundo de forma natural"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet3": {
      "comment": "Third bullet point in the How It Works sheet about saved progress.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your progress is saved, so you can pause and return across multiple sittings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso se guarda, para que puedas pausar y regresar en múltiples sesiones"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Postęp jest zapisywany, więc możesz zrobić przerwę i wrócić przy kolejnym spotkaniu"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt wird gespeichert, damit du pausieren und zu einem anderen Zeitpunkt weitermachen kannst"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre progression est sauvegardée, pour pouvoir faire des pauses et reprendre en plusieurs fois"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O seu progresso é salvo, para que possa pausar e retomar em diferentes momentos"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet4": {
      "comment": "Fourth bullet point in the How It Works sheet about the read-aloud format.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Designed to be read aloud — one person asks, the other tells their story"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado para leerse en voz alta — una persona pregunta, la otra cuenta su historia"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeznaczone do czytania na głos — jedna osoba pyta, druga opowiada swoją historię"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Vorlesen gedacht — eine Person fragt, die andere erzählt ihre Geschichte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu pour être lu à voix haute — une personne pose les questions, l'autre raconte son histoire"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pensado para ser lido em voz alta — uma pessoa pergunta, a outra conta sua história"
          }
        }
      }
    },
