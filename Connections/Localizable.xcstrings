    "home.hint": {
      "comment": "Hint text below the main buttons on the home screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a tone. Follow the prompts.\nSee where it goes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un tono. Sigue las preguntas.\nVe adónde te lleva."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz ton. Odpowiedz na pytania.\nZobacz, dokąd to prowadzi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton wählen. Den Fragen folgen.\nSchauen, wohin es führt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un ton. Suivez les questions.\nVoyez où ça mène."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um tom. Siga as perguntas.\nVeja onde isso leva."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een toon. Volg de vragen.\nKijk waar het naartoe gaat."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トーンを選んで、プロンプトに従って。\nどこへ向かうか、見てみよう。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un tono. Segui le domande.\nVedi dove porta."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj en ton. Följ frågorna.\nSe vart det leder."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg en tone. Følg prompterne.\nSe, hvor det fører hen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg en tone. Følg spørsmålene.\nSe hvor det fører."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse sävy. Seuraa kehotteita.\nKatso, minne se vie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个基调，跟随提示。\n看看会走向哪里。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбери тон, следуй за вопросами.\nПосмотри, куда это приведёт."
          }
        }
      }
    },
