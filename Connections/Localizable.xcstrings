    "lifeStoryIntro.howSheet.footer": {
      "comment": "Closing remark below the bullet points in the How It Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations only happen\nwhen someone knows to ask."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunas conversaciones solo ocurren\ncuando alguien sabe preguntar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niektóre rozmowy zdarzają się tylko wtedy,\ngdy ktoś wie, o co zapytać."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manche Gespräche entstehen nur dann,\nwenn jemand weiß, wie man fragt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certaines conversations n'arrivent\nque lorsque quelqu'un pense à demander."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algumas conversas só acontecem\nquando alguém sabe o que perguntar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sommige gesprekken vinden pas plaats\nals iemand weet wat te vragen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ある会話は、誰かが聞き方を知ったときだけ\n生まれる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alcune conversazioni avvengono solo\nquando qualcuno sa cosa chiedere."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En del samtal sker bara\nnär någon vet vad de ska fråga."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Nogle samtaler sker kun,\nnår nogen ved, hvad der skal spørges om."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Noen samtaler skjer bare\nnår noen vet å spørre."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jotkut keskustelut käydään vasta\nkun joku tietää mitä kysyä."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有些对话只会在\n有人知道该问什么时才会发生。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые разговоры происходят только тогда,\nкогда кто-то знает, что спросить."
          }
        }
      }
    },
