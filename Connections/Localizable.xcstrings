    },
    "fallInLovePlay.complete.body.couples": {
      "comment": "Italic body text on the completion screen shown to couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a moment to appreciate the connection you've built."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toma un momento para apreciar la conexión que han construido."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Znajdź chwilę, by docenić więź, którą zbudowaliście."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimm dir einen Moment, um die Verbindung zu schätzen, die ihr aufgebaut habt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez un moment pour apprécier la connexion que vous avez construite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reserve um momento para valorizar a conexão que vocês construíram."
          }
        }
      }
    },
    "fallInLovePlay.complete.body.friends": {
      "comment": "Italic body text on the completion screen shown to friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You made space for a deeper kind of conversation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiciste espacio para un tipo más profundo de conversación."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zrobiło się miejsce na głębszą rozmowę."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast Raum für ein tieferes Gespräch geschaffen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un espace s'est ouvert pour une conversation plus profonde."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocês abriram espaço para um tipo mais profundo de conversa."
          }
        }
      }
    },
    "fallInLovePlay.complete.subtitle": {
      "comment": "Subtitle on the completion screen noting the user answered all 36 questions.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You stayed for all 36 questions"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te quedaste para las 36 preguntas"
          }
        },
        "pl": {
