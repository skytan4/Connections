    "paywall.general.body": {
      "comment": "Body text on the general paywall screen explaining what the full unlock includes.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get deeper prompts, longer conversations, and guided experiences designed for the moments that matter most."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtén preguntas más profundas, conversaciones más largas y experiencias guiadas diseñadas para los momentos que más importan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzyskaj głębsze pytania, dłuższe rozmowy i prowadzone doświadczenia zaprojektowane na chwile, które mają największe znaczenie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiefere Fragen, längere Gespräche und geführte Erlebnisse – für die Momente, die wirklich zählen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez à des questions plus profondes, des conversations plus longues et des expériences guidées conçues pour les moments qui comptent vraiment."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenha perguntas mais profundas, conversas mais longas e experiências guiadas criadas para os momentos que mais importam."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Krijg diepere vragen, langere gesprekken en begeleide ervaringen voor de momenten die er het meest toe doen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "もっと深いプロンプト、長い会話、大切な瞬間のためのガイド付き体験が手に入る。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottieni prompt più profondi, conversazioni più lunghe ed esperienze guidate pensate per i momenti che contano di più."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Få djupare frågor, längre samtal och guidade upplevelser utformade för de ögonblick som betyder mest."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Få dybere prompts, længere samtaler og guidede oplevelser designet til de øjeblikke, der betyder mest."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Få dypere spørsmål, lengre samtaler og veiledede opplevelser designet for øyeblikkene som betyr mest."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat syvemmät kehotteet, pidemmät keskustelut ja ohjatut kokemukset, jotka on suunniteltu tärkeimpiä hetkiä varten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "获取更深层的提示、更长的对话和引导式体验，为最重要的时刻而设计。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получи доступ к более глубоким вопросам, длинным беседам и направляемым сессиям — созданным для самых важных моментов."
          }
        }
      }
    },
