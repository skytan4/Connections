    "settings.language.appLanguage.accessibilityHint": {
      "comment": "Accessibility hint for the App Language row.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens this app’s settings in iOS Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la configuración de esta app en Configuración de iOS."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwiera ustawienia tej aplikacji w Ustawieniach iOS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnet die App-Einstellungen in den iOS-Einstellungen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre les réglages de cette application dans les Réglages iOS."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre as configurações deste app nas Configurações do iOS."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opent de instellingen van deze app in iOS-instellingen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSの設定でこのアプリの設定を開きます。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre le impostazioni di questa app nelle Impostazioni iOS."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Öppnar den här appens inställningar i iOS Inställningar."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Åbner denne apps indstillinger i iOS Indstillinger."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Åpner denne appens innstillinger i iOS-innstillinger."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa tämän sovelluksen asetukset iOS:n asetuksissa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在iOS设置中打开此应用的设置。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открыть настройки этого приложения в iOS."
          }
        }
      }
    },
    "settings.language.appLanguage.subtitle": {
      "comment": "Subtitle explaining how to change the app language via iOS Settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change this in iOS Settings. If the language option does not appear, add another language in Settings › General › Language & Region first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cámbialo en Configuración de iOS. Si la opción de idioma no aparece, primero agrega otro idioma en Configuración › General › Idioma y región."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmień to w Ustawieniach iOS. Jeśli opcja języka nie pojawi się, najpierw dodaj inny język w Ustawienia › Ogólne › Język i region."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ändere dies in den iOS-Einstellungen. Falls die Sprachoption nicht erscheint, füge zuerst eine weitere Sprache unter Einstellungen › Allgemein › Sprache & Region hinzu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À modifier dans les Réglages iOS. Si l'option de langue n'apparaît pas, ajoutez d'abord une autre langue dans Réglages › Général › Langue et région."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Altere isso nas Configurações do iOS. Se a opção de idioma não aparecer, adicione outro idioma em Configurações › Geral › Idioma e Região primeiro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas dit aan in iOS-instellingen. Als de taaloptie niet verschijnt, voeg dan eerst een andere taal toe via Instellingen › Algemeen › Taal en regio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSの設定から変更できます。言語オプションが表示されない場合は、設定 › 一般 › 言語と地域 で別の言語を追加してください。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifica nelle Impostazioni iOS. Se l'opzione della lingua non appare, aggiungi prima un'altra lingua in Impostazioni › Generali › Lingua e zona."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ändra detta i iOS Inställningar. Om språkalternativet inte visas, lägg till ett annat språk i Inställningar › Allmänt › Språk och region först."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skift dette i iOS Indstillinger. Hvis sprogtilvalget ikke vises, skal du først tilføje et andet sprog under Indstillinger › Generelt › Sprog og region."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Endre dette i iOS-innstillinger. Hvis språkalternativet ikke vises, legg til et annet språk under Innstillinger › Generelt › Språk og region først."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Muuta tätä iOS:n asetuksissa. Jos kielivalinta ei näy, lisää ensin toinen kieli kohdassa Asetukset › Yleiset › Kieli ja alue."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在iOS设置中更改。如果没有看到语言选项，请先在\"设置\">\"通用\">\"语言与地区\"中添加另一种语言。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меняется в настройках iOS. Если не видишь выбор языка, сначала добавь другой язык в «Настройки» → «Основные» → «Язык и регион»."
          }
        }
      }
    },
