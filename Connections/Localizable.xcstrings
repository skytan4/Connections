            "state": "translated",
            "value": "Start Over?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Empezar de nuevo?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacząć od nowa?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neu starten?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recommencer ?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomeçar?"
          }
        }
      }
    },
    "fallInLovePlay.button.previous": {
      "comment": "Button to go back to the previous question during a Fall in Love session.",
