    "sessionPlay.recommendation.prompt.intensityOnly": {
      "comment": "Recommendation teaser when no specific topic is recommended. Arg 1: localized intensity name (e.g. 'Honest').",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on how this session unfolded, we think a %1$@ session could be a good next step. Shall we start it for you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Basándonos en cómo se desarrolló esta sesión, creemos que una sesión %1$@ podría ser un buen siguiente paso. ¿La iniciamos?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na podstawie przebiegu tej sesji myślimy, że sesja w trybie %1$@ mogłaby być dobrym kolejnym krokiem. Mamy ją dla ciebie uruchomić?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Basierend auf dem Verlauf dieser Session denken wir, dass eine %1$@-Session ein guter nächster Schritt sein könnte. Sollen wir sie für dich starten?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "D'après le déroulement de cette session, une session %1$@ pourrait être une bonne prochaine étape. Voulez-vous qu'on la démarre ?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com base em como esta sessão se desenvolveu, achamos que uma sessão no nível %1$@ pode ser um bom próximo passo. Quer que iniciemos para você?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Op basis van hoe deze sessie verliep, denken we dat een %1$@-sessie een goede volgende stap kan zijn. Zullen we die voor je starten?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションの流れを踏まえて、%1$@のセッションが次のステップになりそう。始めてみる？"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In base a come si è svolta questa sessione, pensiamo che una sessione %1$@ potrebbe essere un buon passo successivo. Vuoi che la avviamo per te?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Baserat på hur den här sessionen utvecklades tror vi att en %1$@-session kan vara ett bra nästa steg. Ska vi starta den åt dig?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Baseret på hvordan denne session forløb, tror vi, at en %1$@-session kunne være et godt næste skridt. Skal vi starte den for dig?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Basert på hvordan denne økten utfoldet seg, tror vi en %1$@-økt kan være et godt neste steg. Skal vi starte den for deg?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämän istunnon etenemisen perusteella uskomme, että %1$@-istunto voisi olla hyvä seuraava askel. Aloitetaanko se puolestasi?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据这场对话的走向，我们觉得一场%1$@对话可能是不错的下一步。要为你开始吗？"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Судя по тому, как прошла эта беседа, %1$@ беседа может стать хорошим следующим шагом. Начать для тебя?"
          }
        }
      }
    },
    "sessionPlay.recommendation.prompt.topicAndIntensity": {
      "comment": "Recommendation teaser when both a topic and intensity are recommended. Arg 1: localized topic name. Arg 2: localized intensity name.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on how this session unfolded, we think a session about %1$@ at the %2$@ level could be a good next step. Shall we start it for you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Basándonos en cómo se desarrolló esta sesión, creemos que una sesión sobre %1$@ a nivel %2$@ podría ser un buen siguiente paso. ¿La iniciamos?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na podstawie przebiegu tej sesji myślimy, że sesja o %1$@ na poziomie %2$@ mogłaby być dobrym kolejnym krokiem. Mamy ją dla ciebie uruchomić?"
