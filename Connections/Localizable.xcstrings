          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Op basis van hoe deze sessie verliep, denken we dat een sessie over %1$@ op het %2$@-niveau een goede volgende stap kan zijn. Zullen we die voor je starten?"
          }
        },
        "ja": {
