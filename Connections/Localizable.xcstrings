    "lifeStoryPlay.complete.body": {
      "comment": "Italic closing line on the Life Story completion screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The conversations that matter most are the ones we almost didn't have."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las conversaciones que más importan son las que casi no tuvimos."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozmowy, które mają największe znaczenie, to te, których prawie nie było."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Gespräche, die am meisten zählen, sind oft die, die wir fast nicht geführt hätten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conversations qui comptent le plus sont celles qu'on a failli ne jamais avoir."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As conversas que mais importam são aquelas que quase não aconteceram."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De gesprekken die er het meest toe doen, zijn de gesprekken die we bijna niet hadden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一番大切な会話は、しそびれていたものかもしれない。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le conversazioni più importanti sono quelle che quasi non abbiamo avuto."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "De samtal som betyder mest är de vi nästan inte hade."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "De samtaler, der betyder mest, er dem, vi næsten ikke fik."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Samtalene som betyr mest er de vi nesten ikke hadde."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tärkeimmät keskustelut ovat niitä, joita emme melkein koskaan käy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最重要的对话，往往是那些差点没能发生的。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Самые важные разговоры — это те, которые едва не остались несостоявшимися."
          }
        }
      }
    },
