      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One unlock for deeper conversations, guided journeys, and the questions people remember."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un acceso para conversaciones más profundas, viajes guiados y las preguntas que la gente recuerda."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedno odblokowanie — głębsze rozmowy, prowadzone podróże i pytania, które się pamięta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmal freischalten – für tiefere Gespräche, geführte Reisen und Fragen, die bleiben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un seul accès pour des conversations plus profondes, des parcours guidés et les questions dont on se souvient."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um único desbloqueio para conversas mais profundas, jornadas guiadas e as perguntas que as pessoas não esquecem."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eén aankoop voor diepere gesprekken, begeleide reizen en de vragen die mensen bijblijven."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深い会話、ガイド付きの旅、心に残る質問――ひとつのアンロックで全部。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un solo sblocco per Deeper Conversations, percorsi guidati e le domande che le persone ricordano."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En upplåsning för djupare samtal, guidade resor och de frågor folk minns."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Én oplåsning til dybere samtaler, guidede rejser og de spørgsmål, folk husker."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Én opplåsing for dypere samtaler, veiledede reiser og spørsmålene folk husker."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yksi avaus syvemmille keskusteluille, ohjatuille matkoille ja kysymyksille, jotka jäävät mieleen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次解锁，获得更深层的对话、引导式旅程，以及那些让人难以忘怀的问题。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одна покупка — и ты открываешь более глубокие разговоры, направляемые путешествия и вопросы, которые не забываются."
          }
        }
      }
    },
