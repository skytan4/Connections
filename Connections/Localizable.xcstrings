    "onboarding.page3.body": {
      "comment": "Body text for onboarding page 3.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With a partner, a friend, your family, or just yourself.\nThere's no perfect way to begin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con una pareja, un amigo, tu familia, o contigo mismo.\nNo hay una forma perfecta de comenzar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Z partnerem, przyjacielem, rodziną lub w pojedynkę.\nNie ma idealnego sposobu, żeby zacząć."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit jemandem an deiner Seite, einem Freund, deiner Familie – oder allein.\nEs gibt keinen perfekten Anfang."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avec un partenaire, un ami, votre famille, ou simplement vous-même.\nIl n'y a pas de façon parfaite de commencer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com um parceiro, um amigo, sua família ou apenas você.\nNão existe uma forma perfeita de começar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Met je partner, een vriend, je familie, of gewoon jezelf.\nEr is geen perfecte manier om te beginnen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パートナー、友達、家族、それとも自分だけで。\n完璧な始め方なんてない。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Con un partner, un amico, la tua famiglia, o solo con te stesso.\nNon esiste un modo perfetto per iniziare."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Med en partner, en vän, din familj eller bara dig själv.\nDet finns inget perfekt sätt att börja."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Med en partner, en ven, din familie eller bare dig selv.\nDer er ingen perfekt måde at begynde på."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Med en partner, en venn, familien din eller bare deg selv.\nDet finnes ingen perfekt måte å begynne på."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kumppanin, ystävän, perheesi tai itsesi kanssa.\nPerfektia tapaa aloittaa ei ole."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "和伴侣、朋友、家人一起，或者独自反思。\n没有完美的开始方式。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "С партнёром, друзьями, семьёй — или в одиночестве.\nИдеального способа начать не существует."
          }
        }
      }
    },
    "onboarding.page3.title": {
      "comment": "Title for onboarding page 3.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start where you are"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comienza donde estás"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacznij tam, gdzie jesteś"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fang dort an, wo du bist"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencer là où vous en êtes"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece de onde você está"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin waar je bent"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今いる場所から始める"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia da dove sei"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Börja där du är"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Start, hvor du er"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Begynn der du er"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloita siitä, missä olet"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从此刻开始"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начни прямо сейчас"
          }
        }
      }
    },
    "onboarding.page4.body": {
      "comment": "Body text for onboarding page 4.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose who it's for.\nSet the tone.\nStart talking."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige para quién es.\nEstablece el tono.\nEmpieza a hablar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, dla kogo.\nUstaw ton.\nZacznij rozmawiać."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, für wen es ist.\nTon festlegen.\nEinfach reden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisir pour qui c'est.\nDéfinir le ton.\nCommencer à parler."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha para quem é.\nDefina o tom.\nComece a conversar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies voor wie het is.\nBepaal de toon.\nBegin met praten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誰のために使うかを選んで。\nトーンを決めて。\n話し始めよう。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli per chi è.\nScegli il tono.\nInizia a parlare."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj vem det är för.\nSätt tonen.\nBörja prata."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg hvem det er til.\nSæt tonen.\nBegynd at tale."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvem det er for.\nSett tonen.\nBegynn å snakke."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse kenelle se on.\nAseta sävy.\nAloita puhuminen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择对象。\n设定基调。\n开始对话。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбери собеседника.\nЗадай тон.\nНачни беседу."
          }
        }
      }
    },
