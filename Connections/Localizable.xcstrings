    "sessionSetup.fallInLove.body": {
      "comment": "Description body shown when the Fall in Love topic is selected in session setup.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Questions progress from casual to deeply personal. Your progress is saved so you can pause and return anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las preguntas van de casuales a profundamente personales. Tu progreso se guarda para que puedas pausar y continuar cuando quieras."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pytania przechodzą od swobodnych do głęboko osobistych. Twój postęp jest zapisywany, więc możesz zrobić przerwę i wrócić w dowolnym momencie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fragen werden von locker bis tief persönlich. Dein Fortschritt wird gespeichert – du kannst jederzeit pausieren und weitermachen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les questions progressent du casual au profondément personnel. Votre progression est sauvegardée pour que vous puissiez faire une pause et revenir à tout moment."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As perguntas progridem do casual ao profundamente pessoal. Seu progresso é salvo para você pausar e retomar quando quiser."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vragen lopen op van luchtig naar diep persoonlijk. Je voortgang wordt bewaard, zodat je op elk moment kunt pauzeren en terugkeren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "質問は気軽なものから深くパーソナルなものへと進んでいく。進行状況が保存されるので、いつでも一時停止して戻ってこられる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le domande progrediscono dal casual al profondamente personale. I tuoi progressi vengono salvati in modo da poter fare una pausa e riprendere in qualsiasi momento."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Frågorna går från vardagliga till djupt personliga. Ditt framsteg sparas så att du kan pausa och återvända när som helst."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spørgsmålene skrider frem fra uformelle til dybt personlige. Din fremgang gemmes, så du kan holde pause og vende tilbage når som helst."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Spørsmålene går fra uformelle til dypt personlige. Fremdriften din lagres slik at du kan pause og returnere når som helst."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kysymykset etenevät rennosta syvästi henkilökohtaiseen. Edistymisesi tallentuu, joten voit pitää tauon ja jatkaa milloin tahansa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "问题从轻松逐渐过渡到深入个人。你的进度会自动保存，随时可以暂停和继续。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вопросы плавно переходят от лёгких к глубоко личным. Твой прогресс сохраняется автоматически, можно делать паузы и продолжать в любое время."
          }
        }
      }
    },
