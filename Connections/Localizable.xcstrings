    "favoritesPlay.emptyState.body": {
      "comment": "Body text shown on the Favorites empty state screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the heart on any prompt to save it here for later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el corazón en cualquier pregunta para guardarla aquí para después."
