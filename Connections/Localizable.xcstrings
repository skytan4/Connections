          }
        }
      }
    },
    "settings.language.appLanguage.subtitle": {
      "comment": "Subtitle explaining how to change the app language via iOS Settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change this in iOS Settings. If the language option does not appear, add another language in Settings › General › Language & Region first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cámbialo en Configuración de iOS. Si la opción de idioma no aparece, primero agrega otro idioma en Configuración › General › Idioma y región."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmień to w Ustawieniach iOS. Jeśli opcja języka nie pojawi się, najpierw dodaj inny język w Ustawienia › Ogólne › Język i region."
          }
        }
      }
    },
