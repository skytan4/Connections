    "fallInLoveIntro.whySheet.couples.bullet1": {
      "comment": "First bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When two people take turns answering honest questions, they naturally match each other's openness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando dos personas se turnan para responder preguntas honestas, naturalmente igualan la apertura del otro"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiedy dwie osoby na zmianę odpowiadają na szczere pytania, naturalnie dopasowują poziom swojej otwartości"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn zwei Menschen sich abwechselnd ehrlichen Fragen stellen, öffnen sie sich ganz natürlich füreinander"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand deux personnes répondent à tour de rôle à des questions sincères, elles s'accordent naturellement sur le degré d'ouverture"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando duas pessoas se revezam respondendo perguntas sinceras, naturalmente correspondem à abertura uma da outra"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer twee mensen om beurten eerlijke vragen beantwoorden, spiegelen ze van nature elkaars openheid"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ふたりが正直な質問に交互に答えると、自然と相手の開き方に合わせていく"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando due persone si alternano a rispondere a domande sincere, tendono naturalmente a corrispondere all'apertura dell'altro"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När två personer turas om att svara på ärliga frågor matchar de naturligt varandras öppenhet"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når to mennesker skiftes til at besvare ærlige spørgsmål, spejler de naturligt hinandens åbenhed"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når to mennesker svarer på ærlige spørsmål etter tur, matcher de naturlig hverandres åpenhet"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun kaksi ihmistä vuorotellen vastaa rehellisiin kysymyksiin, he luonnostaan peilaavat toistensa avoimuutta"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当两个人轮流回答真诚的问题时，他们会自然地匹配彼此的开放程度"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда двое поочерёдно отвечают на искренние вопросы, они естественно подстраиваются под уровень открытости друг друга"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feeling genuinely listened to — not just heard — is one of the strongest drivers of closeness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentirse genuinamente escuchado — no solo oído — es uno de los factores más poderosos para generar cercanía"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poczucie, że ktoś naprawdę słucha — nie tylko słyszy — jest jednym z najsilniejszych czynników budujących bliskość"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wirklich gehört zu werden — nicht nur wahrgenommen — ist einer der stärksten Treiber von Nähe"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se sentir vraiment écouté — pas seulement entendu — est l'un des moteurs les plus puissants de la proximité"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentir-se genuinamente ouvido — não apenas escutado — é um dos maiores impulsionadores da proximidade"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je écht gehoord voelen — niet alleen aangehoord — is een van de sterkste drijfveren van nabijheid"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ただ聞かれるのではなく、本当に耳を傾けてもらえる感覚が、近さの最大の原動力になる"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentirsi davvero ascoltati — non solo sentiti — è uno dei fattori più potenti di vicinanza"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Att verkligen bli lyssnad på – inte bara hörd – är en av de starkaste drivkrafterna för nearhet"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "At føle sig virkelig lyttet til — ikke bare hørt — er en af de stærkeste drivkræfter bag nærhed"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Å føle seg genuint lyttet til – ikke bare hørt – er en av de sterkeste drivkreftene for nærhet"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Se, että kokee tulevansa aidosti kuulluksi – ei vain kuunnelluksi – on yksi voimakkaimmista läheisyyden rakentajista"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "被真正倾听——而不只是听到——是拉近距离最强大的力量之一"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быть по-настоящему услышанным — не просто выслушанным — это одна из самых мощных сил сближения"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vulnerability doesn't just build trust. It signals that trust already exists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnerabilidad no solo construye confianza. Señala que la confianza ya existe."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wrażliwość nie tylko buduje zaufanie. Sygnalizuje, że zaufanie już istnieje."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verletzlichkeit schafft nicht nur Vertrauen. Sie zeigt, dass dieses Vertrauen bereits da ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnérabilité ne fait pas que construire la confiance. Elle signale que cette confiance existe déjà."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A vulnerabilidade não apenas constrói confiança. Ela sinaliza que a confiança já existe."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kwetsbaarheid bouwt niet alleen vertrouwen op. Het laat zien dat vertrouwen er al is."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "弱さを見せることは、信頼を育てるだけじゃない。信頼がすでにあることを示している。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnerabilità non costruisce solo fiducia. Segnala che la fiducia esiste già."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sårbarhet bygger inte bara förtroende. Det signalerar att förtroendet redan finns."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sårbarhed opbygger ikke bare tillid. Det signalerer, at tilliden allerede findes."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sårbarhet bygger ikke bare tillit. Det signaliserer at tillit allerede eksisterer."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Haavoittuvuus ei vain rakenna luottamusta. Se viestii, että luottamus on jo olemassa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "脆弱不仅能建立信任，更表明信任已经存在。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уязвимость не только строит доверие — она говорит о том, что доверие уже есть."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The conversations that deepen a relationship are rarely dramatic. They're the ones where someone feels met."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las conversaciones que profundizan una relación rara vez son dramáticas. Son aquellas en las que alguien se siente visto."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozmowy, które pogłębiają związek, rzadko są dramatyczne. To te, w których ktoś poczuł się naprawdę zrozumiany."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Gespräche, die eine Beziehung vertiefen, sind selten dramatisch. Es sind die Momente, in denen sich jemand wirklich gesehen fühlt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conversations qui approfondissent une relation sont rarement spectaculaires. Ce sont celles où quelqu'un se sent vraiment rejoint."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As conversas que aprofundam um relacionamento raramente são dramáticas. São aquelas em que alguém se sente verdadeiramente visto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesprekken die een relatie verdiepen zijn zelden dramatisch. Het zijn de gesprekken waarbij iemand zich écht begrepen voelt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "関係を深める会話は、大げさなものじゃない。誰かが「わかってもらえた」と感じる瞬間がそれ。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le conversazioni che approfondiscono una relazione sono raramente drammatiche. Sono quelle in cui qualcuno si sente incontrato."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "De samtal som fördjupar en relation är sällan dramatiska. Det är de där någon känner sig mött."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "De samtaler, der uddyber et forhold, er sjældent dramatiske. Det er dem, hvor nogen føler sig mødt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Samtalene som fordyper et forhold er sjelden dramatiske. Det er de der noen føler seg møtt."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Keskustelut, jotka syventävät suhdetta, ovat harvoin dramaattisia. Ne ovat niitä, joissa toinen tuntee tulleensa kohdatuksi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能加深关系的对话很少是戏剧性的。而是那些让人感到被理解的对话。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разговоры, которые углубляют отношения, редко бывают драматичными. Это те, в которых ты чувствуешь, что тебя поняли."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.footer": {
      "comment": "Closing remark in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't fall in love all at once.\nYou build it — one honest moment at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te enamoras de golpe.\nLo construyes — un momento honesto a la vez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zakochujesz się raz na zawsze.\nBudujesz to — jedna szczera chwila na raz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Man verliebt sich nicht auf einmal.\nMan baut es auf — einen ehrlichen Moment nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On ne tombe pas amoureux d'un coup.\nÇa se construit — un moment honnête à la fois."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não nos apaixonamos de uma vez só.\nConstruímos isso — um momento honesto de cada vez."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verliefd worden overkomt je niet in één keer.\nJe bouwt het op — één eerlijk moment tegelijk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "恋は一度に落ちるものじゃない。\n正直な瞬間を重ねて、積み上げていくもの。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non ci si innamora tutto in una volta.\nLo si costruisce — un momento onesto alla volta."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Man förälskar sig inte på en gång.\nMan bygger det – ett ärligt ögonblick i taget."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Man forelsker sig ikke på én gang.\nMan bygger det — ét ærligt øjeblik ad gangen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du faller ikke forelsket på én gang.\nDu bygger det – ett ærlig øyeblikk om gangen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Rakastuminen ei tapahdu kerralla.\nSen rakentaa – yksi rehellinen hetki kerrallaan."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "爱不是一瞬间的事。\n它是一个个真诚时刻堆砌而成的。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Любовь — это не один момент.\nЭто множество честных мгновений."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet1": {
      "comment": "First bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When one person shares something real, others tend to match that openness — without being asked"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando una persona comparte algo real, los demás tienden a igualar esa apertura — sin que se les pida"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiedy jedna osoba dzieli się czymś prawdziwym, inne zazwyczaj dopasowują tę otwartość — bez pytania"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn eine Person etwas Echtes teilt, öffnen sich andere ganz von selbst — ohne dass man sie darum bitten müsste"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand quelqu'un partage quelque chose de vrai, les autres ont tendance à suivre cette ouverture — sans qu'on le demande"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando alguém compartilha algo verdadeiro, os outros tendem a corresponder essa abertura — sem precisar ser pedido"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer iemand iets echts deelt, neigen anderen die openheid te spiegelen — zonder dat je erom hoeft te vragen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "誰かが本音を話すと、頼まれなくても周りが自然とその開き方に合わせていく"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando una persona condivide qualcosa di vero, le altre tendono a corrispondere quell'apertura — senza essere invitate"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När en person delar något verkligt brukar andra matcha den öppenheten – utan att bli tillfrågade"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når én person deler noget ægte, har andre en tendens til at matche den åbenhed — uden at blive bedt om det"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når én person deler noe ekte, pleier andre å matche den åpenheten – uten å bli bedt om det"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun yksi jakaa jotain todellista, muut yleensä vastaavat samalla avoimuudella – ilman pyyntöä"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当一个人分享了真实的东西，其他人往往会不自觉地回以同样的坦诚"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда один человек делится чем-то настоящим, другой обычно невольно отвечает той же откровенностью"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Asking a genuine question and actually listening is one of the simplest ways to deepen a friendship"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacer una pregunta genuina y escuchar de verdad es una de las formas más simples de profundizar una amistad"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadanie szczerego pytania i prawdziwe słuchanie to jeden z najprostszych sposobów na pogłębienie przyjaźni"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine aufrichtige Frage stellen und wirklich zuhören ist einer der einfachsten Wege, eine Freundschaft zu vertiefen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poser une vraie question et écouter réellement est l'une des façons les plus simples d'approfondir une amitié"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazer uma pergunta genuína e realmente escutar é uma das formas mais simples de aprofundar uma amizade"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een oprechte vraag stellen en écht luisteren is een van de eenvoudigste manieren om een vriendschap te verdiepen"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本気の質問をして、ちゃんと聞くこと――それが友達をもっと深くする、一番シンプルな方法"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fare una domanda sincera e ascoltare davvero è uno dei modi più semplici per approfondire un'amicizia"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Att ställa en genuin fråga och faktiskt lyssna är ett av de enklaste sätten att fördjupa en vänskap"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "At stille et oprigtigt spørgsmål og rent faktisk lytte er en af de enkleste måder at uddybe et venskab på"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Å stille et oppriktig spørsmål og faktisk lytte er en av de enkleste måtene å fordype et vennskap"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aito kysymys ja todellinen kuunteleminen on yksi yksinkertaisimmista tavoista syventää ystävyyttä"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提一个真诚的问题并认真倾听，是加深友谊最简单的方式之一"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задать искренний вопрос и внимательно выслушать — один из самых простых способов углубить дружбу"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trust grows in small moments — when someone feels heard, not just talked to"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La confianza crece en pequeños momentos — cuando alguien se siente escuchado, no solo hablado"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaufanie rośnie w małych chwilach — gdy ktoś czuje się wysłuchany, a nie tylko wysłuchiwany"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertrauen wächst in kleinen Momenten — wenn jemand das Gefühl hat, gehört zu werden, nicht nur bespielt zu werden"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La confiance grandit dans les petits moments — quand quelqu'un se sent écouté, pas seulement interpellé"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A confiança cresce em pequenos momentos — quando alguém se sente ouvido, não apenas falado"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertrouwen groeit in kleine momenten — wanneer iemand zich gehoord voelt, niet alleen aangesproken"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "信頼は小さな瞬間に育つ――ただ話しかけられるんじゃなく、ちゃんと聞いてもらえたと感じるとき"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La fiducia cresce nei piccoli momenti — quando qualcuno si sente ascoltato, non solo destinatario di parole"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Förtroende växer i små ögonblick – när någon känner sig hörd, inte bara tilltalad"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillid vokser i små øjeblikke — når nogen føler sig hørt, ikke bare talt til"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillit vokser i små øyeblikk – når noen føler seg hørt, ikke bare snakket til"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Luottamus kasvaa pienissä hetkissä – kun toinen tuntee tulleensa kuulluksi, ei vain puhutelluksi"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "信任在细小的时刻中生长——当一个人感到被倾听，而不只是被搭话"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доверие растёт в маленьких моментах — когда человек чувствует, что его услышали, а не просто ответили"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most friendships stay at the surface not because people don't care, but because no one goes first"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La mayoría de las amistades se quedan en la superficie no porque no les importe, sino porque nadie da el primer paso"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Większość przyjaźni pozostaje na powierzchni nie dlatego, że ludziom nie zależy, ale dlatego, że nikt nie zaczyna pierwszy"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die meisten Freundschaften bleiben an der Oberfläche — nicht weil es niemanden interessiert, sondern weil niemand den ersten Schritt macht"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La plupart des amitiés restent en surface non pas parce que les gens ne tiennent pas les uns aux autres, mais parce que personne ne fait le premier pas"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A maioria das amizades fica na superfície não porque as pessoas não se importam, mas porque ninguém dá o primeiro passo"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De meeste vriendschappen blijven oppervlakkig, niet omdat mensen het niet kunnen schelen, maar omdat niemand de eerste stap zet"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友情が表面のまま止まるのは、気にかけていないからじゃない。誰も先に踏み出さないから。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La maggior parte delle amicizie resta in superficie non perché le persone non ci tengano, ma perché nessuno fa il primo passo"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "De flesta vänskaper stannar på ytan – inte för att folk inte bryr sig, utan för att ingen tar det första steget"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "De fleste venskaber forbliver på overfladen ikke fordi folk ikke bryder sig, men fordi ingen tager det første skridt"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "De fleste vennskap forblir overfladiske ikke fordi folk ikke bryr seg, men fordi ingen går først"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Useimmat ystävyydet pysyvät pinnallisina ei siksi, että ihmiset eivät välitä, vaan koska kukaan ei ota ensin askelta"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "大多数友谊停留在表面，不是因为不在乎，而是因为没人先迈出那一步"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Большинство дружеских отношений остаются поверхностными не потому, что людям всё равно, а потому что никто не решается сделать первый шаг"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.footer": {
      "comment": "Closing remark in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The deepest friendships aren't found.\nThey're built — one real conversation at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las amistades más profundas no se encuentran.\nSe construyen — una conversación real a la vez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najgłębszych przyjaźni się nie znajduje.\nBuduje się je — jedna prawdziwa rozmowa na raz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die tiefsten Freundschaften findet man nicht.\nMan baut sie — ein echtes Gespräch nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les amitiés les plus profondes ne se trouvent pas.\nElles se construisent — une vraie conversation à la fois."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As amizades mais profundas não são encontradas.\nSão construídas — uma conversa verdadeira de cada vez."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De diepste vriendschappen vind je niet zomaar.\nZe worden gebouwd — één echt gesprek tegelijk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深い友情は出会うものじゃない。\n本物の会話を重ねて、築いていくもの。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le amicizie più profonde non si trovano.\nSi costruiscono — una conversazione vera alla volta."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "De djupaste vänskaperna hittas inte.\nDe byggs – ett riktigt samtal i taget."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "De dybeste venskaber findes ikke.\nDe bygges — én ægte samtale ad gangen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "De dypeste vennskapene finnes ikke.\nDe bygges – én ekte samtale om gangen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Syvimmät ystävyydet eivät löydy.\nNe rakennetaan – yksi aito keskustelu kerrallaan."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最深的友谊不是偶然发现的。\n它是一次次真诚对话建立起来的。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глубокая дружба не возникает случайно.\nОна строится честный разговор за честным разговором."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.title": {
      "comment": "Title heading rendered at the top of the Why This Works sheet.",
      "extractionState": "manual",
      "localizations": {
