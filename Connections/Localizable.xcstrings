    "depthLevel.warmUp.title": {
      "comment": "Title for the Warm Up depth level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warm Up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Calentamiento"
          }
        },
        "pl": {
