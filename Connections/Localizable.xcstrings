    "summary.nextStep.deepDive": {
      "comment": "Next-step message shown after the user reached the Deep Dive depth level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You reached the deep end. Give yourself credit for that."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegaste hasta el fondo. Date crédito por eso."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotarłeś do głębiny. Daj sobie za to uznanie."
          }
        }
      }
    },
    "summary.nextStep.deepToUnfiltered": {
      "comment": "Next-step nudge after high go-deeper engagement. Arg 1: localized name of the Unfiltered intensity setting.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You like to go deep. %1$@ mode might be your speed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te gusta ir profundo. El modo %1$@ puede ser tu velocidad."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lubisz sięgać głęboko. Tryb %1$@ może być dla ciebie."
          }
        }
      }
    },
    "summary.nextStep.lightToHonest": {
      "comment": "Next-step nudge after a light, shallow session. Arg 1: localized name of the Honest intensity setting.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you're ready, %1$@ mode has more to offer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando estés listo, el modo %1$@ tiene más por ofrecer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W swoim czasie tryb %1$@ ma więcej do zaoferowania."
          }
        }
      }
    },
    "summary.nextStep.selective": {
      "comment": "Next-step suggestion shown after a session where the user skipped many prompts.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next time, try staying with a prompt that makes you pause."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La próxima vez, intenta quedarte con una pregunta que te haga pausar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następnym razem spróbuj zostać przy pytaniu, które powoduje pauzę."
          }
        }
      }
    },
    "summary.reflection.curious": {
      "comment": "Reflection line shown when the user used Go Deeper multiple times.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You stayed curious and kept leaning in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te mantuviste curioso y seguiste adentrándote."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciekawość prowadziła coraz dalej."
          }
        }
      }
    },
    "summary.reflection.honesty": {
      "comment": "Second reflection line shown after very high go-deeper engagement combined with deep-dive depth.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There was real honesty in this one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hubo honestidad real en esta sesión."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W tej sesji była prawdziwa szczerość."
          }
        }
      }
    },
    "summary.reflection.instincts": {
      "comment": "Reflection line shown when the user skipped a notable portion of prompts.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You trusted your instincts on what to stay with."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Confiaste en tu instinto sobre qué quedarte."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Instynkt wiedział, przy czym zostać."
          }
        }
      }
    },
    "summary.reflection.openedUp": {
      "comment": "Reflection line shown when the session reached the Deep Dive depth level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The conversation opened up as you went along."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conversación se fue abriendo a medida que avanzaban."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozmowa otwierała się w miarę, jak szło."
          }
        }
      }
    },
    "summary.reflection.present": {
      "comment": "Default reflection line shown when no specific engagement pattern was detected.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You stayed present with each prompt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te mantuviste presente con cada pregunta."
          }
        },
        "pl": {
