    "fallInLoveIntro.body.couples": {
      "comment": "Body paragraph shown to couples on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not by chance — but through attention, honesty, and shared moments.\n\nA series of thoughtfully designed questions can deepen connection, spark curiosity, and bring you closer — one conversation at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No por casualidad — sino a través de la atención, la honestidad y los momentos compartidos.\n\nUna serie de preguntas cuidadosamente diseñadas puede profundizar la conexión, despertar la curiosidad y acercarlos — una conversación a la vez."
          }
        }
      }
    },
    "fallInLoveIntro.body.friends": {
      "comment": "Body paragraph shown to friends on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations create clarity, trust, and unexpected connection.\n\nThese questions are designed to help two people move past surface-level talk and into something more honest, open, and real."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunas conversaciones crean claridad, confianza y conexión inesperada.\n\nEstas preguntas están diseñadas para ayudar a dos personas a ir más allá de la charla superficial y llegar a algo más honesto, abierto y real."
          }
        }
      }
    },
    "fallInLoveIntro.button.start": {
      "comment": "Primary button on the Fall in Love intro screen that starts the session.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start session"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comenzar sesión"
          }
        }
      }
    },
    "fallInLoveIntro.button.whyThisWorks": {
      "comment": "Secondary button on the Fall in Love intro screen that opens the Why This Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why this works"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por qué funciona"
          }
        }
      }
    },
    "fallInLoveIntro.dontShowAgain": {
      "comment": "Label for the Don't Show Again checkbox on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't show this again"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No mostrar esto de nuevo"
          }
        }
      }
    },
    "fallInLoveIntro.title.couples": {
      "comment": "Screen title shown to couples on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fall in love again"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enamorarse de nuevo"
          }
        }
      }
    },
    "fallInLoveIntro.title.friends": {
      "comment": "Screen title shown to friends on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get closer"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acercarse más"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.button.gotIt": {
      "comment": "Dismiss button at the bottom of the Why This Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Got it"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendido"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet1": {
      "comment": "First bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When two people take turns answering honest questions, they naturally match each other's openness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando dos personas se turnan para responder preguntas honestas, naturalmente igualan la apertura del otro"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feeling genuinely listened to — not just heard — is one of the strongest drivers of closeness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentirse genuinamente escuchado — no solo oído — es uno de los factores más poderosos para generar cercanía"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vulnerability doesn't just build trust. It signals that trust already exists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnerabilidad no solo construye confianza. Señala que la confianza ya existe."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The conversations that deepen a relationship are rarely dramatic. They're the ones where someone feels met."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las conversaciones que profundizan una relación rara vez son dramáticas. Son aquellas en las que alguien se siente visto."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.footer": {
      "comment": "Closing remark in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't fall in love all at once.\nYou build it — one honest moment at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te enamoras de golpe.\nLo construyes — un momento honesto a la vez."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet1": {
      "comment": "First bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When one person shares something real, others tend to match that openness — without being asked"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando una persona comparte algo real, los demás tienden a igualar esa apertura — sin que se les pida"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Asking a genuine question and actually listening is one of the simplest ways to deepen a friendship"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacer una pregunta genuina y escuchar de verdad es una de las formas más simples de profundizar una amistad"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trust grows in small moments — when someone feels heard, not just talked to"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La confianza crece en pequeños momentos — cuando alguien se siente escuchado, no solo hablado"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most friendships stay at the surface not because people don't care, but because no one goes first"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La mayoría de las amistades se quedan en la superficie no porque no les importe, sino porque nadie da el primer paso"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.footer": {
      "comment": "Closing remark in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The deepest friendships aren't found.\nThey're built — one real conversation at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las amistades más profundas no se encuentran.\nSe construyen — una conversación real a la vez."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.title": {
      "comment": "Title heading rendered at the top of the Why This Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why this works"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por qué funciona"
          }
        }
      }
    },
    "fallInLovePlay.alert.startOver.confirm": {
      "comment": "Destructive button in the Start Over confirmation alert that resets Fall in Love progress.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset"
