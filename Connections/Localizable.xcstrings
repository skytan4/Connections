    "fallInLovePlay.alert.startOver.message": {
      "comment": "Message body in the Start Over confirmation alert explaining what reset does.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will reset your progress back to Question 1. This is useful when starting with a new person."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reiniciará tu progreso a la Pregunta 1. Es útil cuando comienzas con una nueva persona."
          }
        }
      }
    },
    "fallInLovePlay.alert.startOver.title": {
