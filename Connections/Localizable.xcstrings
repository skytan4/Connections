    "lifeStoryIntro.body": {
      "comment": "Body paragraph on the Life Story intro screen describing the purpose of the flow.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A guided conversation for asking parents, grandparents, or older relatives the questions you may wish you had asked sooner."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una conversación guiada para hacer a padres, abuelos o familiares mayores las preguntas que quizás desearías haber hecho antes."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozmowa przewodnia — pytania do rodziców, dziadków lub starszych bliskich, które możesz żałować, że nie padły wcześniej."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein geführtes Gespräch — für die Fragen, die du Eltern, Großeltern oder älteren Verwandten stellen möchtest, bevor es vielleicht zu spät ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une conversation guidée pour poser aux parents, grands-parents ou proches plus âgés les questions que vous auriez peut-être aimé poser plus tôt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma conversa guiada para fazer aos pais, avós ou parentes mais velhos as perguntas que você pode desejar ter feito antes."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een begeleide sessie om ouders, grootouders of oudere familieleden de vragen te stellen die je misschien eerder had willen stellen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "親、祖父母、年上の親族に、もっと早く聞いておけばよかったと思うような質問をするための、ガイド付き会話。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una conversazione guidata per porre a genitori, nonni o parenti anziani le domande che avresti voluto fare prima."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ett guidat samtal för att ställa föräldrar, far- och morföräldrar eller äldre släktingar de frågor du kanske önskar att du hade ställt tidigare."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En guidet samtale til at stille forældre, bedsteforældre eller ældre slægtninge de spørgsmål, du måske ønsker, du havde stillet tidligere."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En veiledet samtale for å stille foreldre, besteforeldre eller eldre slektninger spørsmålene du kanskje skulle ønske du hadde stilt tidligere."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohjattu keskustelu vanhemmille, isovanhemmille tai vanhemmille sukulaisille esitettäviä kysymyksiä varten – kysymyksiä, joita olet ehkä toivonut kysyväsi aiemmin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一场引导式对话，帮助你向父母、祖父母或年长的亲人提出那些你可能希望早点问的问题。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Беседа с подсказками, которая помогает задавать родителям, бабушкам и дедушкам или пожилым близким вопросы, которые ты, возможно, хотел задать раньше."
          }
        }
      }
    },
