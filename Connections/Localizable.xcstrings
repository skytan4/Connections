    "settings.reset.alert.message": {
      "comment": "Message body in the reset confirmation alert.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will restore your preferences to their default values."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto restaurará tus preferencias a sus valores predeterminados."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przywróci to domyślne wartości preferencji."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Einstellungen werden auf die Standardwerte zurückgesetzt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela restaurera vos préférences à leurs valeurs par défaut."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso vai restaurar suas preferências para os valores padrão."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit zet je voorkeuren terug naar de standaardwaarden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定をデフォルトの値に戻します。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue preferenze verranno ripristinate ai valori predefiniti."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här återställer dina inställningar till standardvärdena."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette gendanner dine præferencer til deres standardværdier."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil gjenopprette preferansene dine til standardverdiene."
          }
        },
        "fi": {
