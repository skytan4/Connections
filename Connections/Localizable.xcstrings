    "settings.purpose.body": {
      "comment": "Body paragraph in the Purpose sheet in Settings.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is designed to help people move beyond surface-level talk and into more meaningful connection. Whether you're using it with a partner, friend, family member, or for solo reflection, the prompts are meant to create honesty, curiosity, and emotional presence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app está diseñada para ayudar a las personas a ir más allá de las conversaciones superficiales y hacia una conexión más significativa. Ya sea que la uses con una pareja, amigo, familiar, o para la reflexión personal, las preguntas están pensadas para crear honestidad, curiosidad y presencia emocional."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacja jest zaprojektowana, by pomagać ludziom wychodzić poza powierzchowną rozmowę i budować głębszą więź. Niezależnie od tego, czy korzystasz z niej z partnerem, przyjacielem, członkiem rodziny, czy do refleksji solo, pytania mają tworzyć szczerość, ciekawość i emocjonalną obecność."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App hilft dabei, über oberflächliche Gespräche hinauszugehen und echte Verbindung zu schaffen. Ob mit dem Gegenüber, einer Freundin oder einem Freund, einem Familienmitglied oder zur eigenen Reflexion – die Fragen sollen Ehrlichkeit, Neugier und emotionale Präsenz fördern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette application est conçue pour aider les gens à aller au-delà des conversations superficielles et vers une connexion plus profonde. Que vous l'utilisiez avec un partenaire, un ami, un membre de votre famille, ou pour une réflexion solo, les invites visent à créer honnêteté, curiosité et présence émotionnelle."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app foi criado para ajudar as pessoas a ir além das conversas superficiais e construir conexões mais significativas. Seja com um parceiro, amigo, familiar ou para reflexão individual, as perguntas são pensadas para criar honestidade, curiosidade e presença emocional."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze app is bedoeld om mensen verder te helpen dan oppervlakkige gesprekken, naar meer betekenisvolle verbinding. Of je hem nu gebruikt met je partner, een vriend, een familielid of voor persoonlijke reflectie — de vragen zijn bedoeld om eerlijkheid, nieuwsgierigheid en emotionele aanwezigheid te stimuleren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは、表面的な会話を超えて、もっと深いつながりへと進むための場所として作られた。パートナー、友達、家族、ひとりの振り返りどんな使い方でも、プロンプトは正直さ、好奇心、感情的な存在感を生み出すために設計されている。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa app è pensata per aiutare le persone ad andare oltre le conversazioni superficiali e verso una connessione più significativa. Che tu la usi con un partner, un amico, un familiare o per la riflessione personale, i prompt sono concepiti per creare onestà, curiosità e presenza emotiva."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den här appen är utformad för att hjälpa människor att gå bortom ytliga samtal och in i mer meningsfull kontakt. Oavsett om du använder den med en partner, vän, familjemedlem eller för egenreflektion, är frågorna avsedda att skapa ärlighet, nyfikenhet och känslomässig närvaro."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne app er designet til at hjælpe folk med at komme ud over overfladisk snak og ind i mere meningsfuld forbindelse. Uanset om du bruger den med en partner, en ven, et familiemedlem eller til selvrefleksion, er prompterne ment til at skabe ærlighed, nysgerrighed og følelsesmæssig tilstedeværelse."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne appen er designet for å hjelpe folk å gå forbi overfladisk prat og inn i mer meningsfull forbindelse. Enten du bruker den med en partner, venn, familiemedlem eller for selvrefleksjon, er spørsmålene ment å skape ærlighet, nysgjerrighet og emosjonell tilstedeværelse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä sovellus on suunniteltu auttamaan ihmisiä siirtymään pintakeskustelusta kohti merkityksellisempää yhteyttä. Olitpa käyttämässä sitä kumppanin, ystävän, perheenjäsenen tai itsereflektioon, kehotteet on tarkoitettu luomaan rehellisyyttä, uteliaisuutta ja emotionaalista läsnäoloa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这款应用旨在帮助人们超越表面的寒暄，走向更有意义的连接。无论你是和伴侣、朋友、家人一起使用，还是独自反思，这些提示都致力于创造真诚、好奇和情感的交流。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приложение помогает людям выйти за рамки поверхностных разговоров и прийти к более значимой близости. Используешь ли ты его с партнёром, друзьями, семьёй или в одиночестве — эти вопросы созданы для честного, любопытного и душевного общения."
          }
        }
      }
    },
