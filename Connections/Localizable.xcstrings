    "connectionLevel.connected.message": {
      "comment": "Summary message shown when users reach the Connected level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This became more moving as you stayed with it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se volvió más emotivo mientras seguiste adelante."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Im dłużej trwała ta rozmowa, tym bardziej poruszała."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wurde bewegender, je länger du dabei geblieben bist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La conversation a pris de la profondeur au fil du temps."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Foi ficando mais tocante conforme você permaneceu com isso."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het werd indringender naarmate je ermee bleef."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続けるうちに、だんだん深まっていった。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È diventato più toccante man mano che andavate avanti."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här blev mer rörande ju längre ni höll i det."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det blev mere bevægende, jo længere I blev ved."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette ble mer rørende jo lenger dere holdt på."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tästä tuli koskettavampaa, kun jatkoit eteenpäin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你们越深入，这段对话就越触动人心。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чем глубже вы заходите, тем больше этот разговор задевает."
          }
        }
      }
    },
