    "summary.nextStep.deepDive": {
      "comment": "Next-step message shown after the user reached the Deep Dive depth level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You reached the deep end. Give yourself credit for that."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegaste hasta el fondo. Date crédito por eso."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotarłeś do głębiny. Daj sobie za to uznanie."
