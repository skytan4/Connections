    "lifeStoryIntro.tagline": {
      "comment": "Smaller tagline below the body on the Life Story intro screen listing conversation themes.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore childhood, love, work, hardship, family history, and legacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Explora la infancia, el amor, el trabajo, las dificultades, la historia familiar y el legado."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odkryj dzieciństwo, miłość, pracę, trudności, historię rodziny i dziedzictwo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kindheit, Liebe, Arbeit, schwere Zeiten, Familiengeschichte und Vermächtnis erkunden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Explorer l'enfance, l'amour, le travail, les épreuves, l'histoire familiale et l'héritage."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore infância, amor, trabalho, dificuldades, história familiar e legado."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verken kindertijd, liefde, werk, tegenslag, familiegeschiedenis en nalatenschap."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "子ども時代、愛、仕事、困難、家族の歴史、受け継ぐものを探る。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esplora infanzia, amore, lavoro, difficoltà, storia familiare ed eredità."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Utforska barndom, kärlek, arbete, motgångar, familjehistoria och arv."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Udforsk barndom, kærlighed, arbejde, modgang, familiehistorie og arv."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Utforsk barndom, kjærlighet, arbeid, motgang, familiehistorie og arv."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutki lapsuutta, rakkautta, työtä, vastoinkäymisiä, perheen historiaa ja perintöä."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "探索童年、爱情、工作、磨难、家族历史与传承。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Детство, любовь, работа, трудности, история семьи и наследие."
          }
        }
      }
    },
