    "summary.nextStep.deepDive": {
      "comment": "Next-step message shown after the user reached the Deep Dive depth level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You reached the deep end. Give yourself credit for that."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegaste hasta el fondo. Date crédito por eso."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotarłeś do głębiny. Daj sobie za to uznanie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast die Tiefe erreicht. Das ist etwas wert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les profondeurs ont été atteintes. C'est quelque chose qui mérite d'être reconnu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você chegou ao fundo. Dê crédito a si mesmo por isso."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt de diepte bereikt. Geef jezelf daarvoor de credits."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深いところまで達した。それは誇っていい。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai raggiunto le acque profonde. Dattene il merito."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du nådde djupet. Ge dig själv kredit för det."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du nåede det dybe vand. Giv dig selv credit for det."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du nådde det dype enden. Gi deg selv kredit for det."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pääsit syvään päähän. Anna itsellesi tunnustus siitä."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你触及了最深处。这值得肯定。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ты добрался до самой глубины. Это стоит отметить."
          }
        }
      }
    },
    "summary.nextStep.deepToUnfiltered": {
      "comment": "Next-step nudge after high go-deeper engagement. Arg 1: localized name of the Unfiltered intensity setting.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You like to go deep. %1$@ mode might be your speed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te gusta ir profundo. El modo %1$@ puede ser tu velocidad."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lubisz sięgać głęboko. Tryb %1$@ może być dla ciebie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du gehst gern in die Tiefe. %1$@-Modus könnte dein Tempo sein."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'envie d'aller en profondeur est là. Le mode %1$@ pourrait être le bon rythme."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você gosta de ir fundo. O modo %1$@ pode ser o seu ritmo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je gaat graag de diepte in. %1$@-modus is misschien jouw tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "深く行くのが好きなんだね。%1$@モードがちょうどいいかも。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti piace andare in profondità. La modalità %1$@ potrebbe fare al caso tuo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du gillar att gå djupt. %1$@-läget kan vara rätt fart för dig."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan lide at gå dybt. %1$@-tilstanden er måske din hastighed."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du liker å gå dypt. %1$@-modus kan passe deg."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidät syvälle menemisestä. %1$@-tila saattaa olla sinulle sopiva vauhti."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你喜欢深入。%1$@模式可能更适合你。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тебе нравится глубина. Режим %1$@ может подойти тебе больше."
          }
        }
      }
    },
    "summary.nextStep.lightToHonest": {
      "comment": "Next-step nudge after a light, shallow session. Arg 1: localized name of the Honest intensity setting.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you're ready, %1$@ mode has more to offer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando estés listo, el modo %1$@ tiene más por ofrecer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W swoim czasie tryb %1$@ ma więcej do zaoferowania."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du bereit bist, hat der %1$@-Modus mehr zu bieten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand le moment sera venu, le mode %1$@ a encore plus à offrir."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando estiver pronto, o modo %1$@ tem mais a oferecer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je er klaar voor bent, heeft de %1$@-modus meer te bieden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備ができたら、%1$@モードにはもっと先がある。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando sei pronto, la modalità %1$@ ha altro da offrire."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "När du är redo har %1$@-läget mer att erbjuda."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du er klar, har %1$@-tilstanden mere at byde på."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du er klar, har %1$@-modus mer å by på."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun olet valmis, %1$@-tilalla on enemmän tarjottavaa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备好了的话，%1$@模式有更多值得探索的。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда будешь готов, в режиме %1$@ есть ещё что исследовать."
          }
        }
      }
    },
    "summary.nextStep.selective": {
      "comment": "Next-step suggestion shown after a session where the user skipped many prompts.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next time, try staying with a prompt that makes you pause."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La próxima vez, intenta quedarte con una pregunta que te haga pausar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następnym razem spróbuj zostać przy pytaniu, które powoduje pauzę."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuch beim nächsten Mal, bei einem Prompt zu bleiben, der dich innehalten lässt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La prochaine fois, essayez de rester avec une invite qui vous fait hésiter."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Na próxima vez, tente ficar com uma pergunta que te faz pausar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Probeer de volgende keer bij een vraag te blijven die je doet stilstaan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次は、立ち止まらせるプロンプトにじっくり向き合ってみて。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La prossima volta, prova a soffermarti su un prompt che ti fa esitare."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nästa gång, försök stanna kvar vid en fråga som får dig att pausa."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Næste gang, prøv at blive ved en prompt, der får dig til at holde pause."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Neste gang, prøv å bli med et spørsmål som får deg til å stoppe opp."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuraavalla kerralla yritä pysyä kehotteen äärellä, joka saa sinut pysähtymään."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次试着在让你停下来思考的提示上多停留一会儿。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В следующий раз попробуй задержаться на вопросах, которые заставили тебя остановиться."
          }
        }
      }
    },
    "summary.reflection.curious": {
      "comment": "Reflection line shown when the user used Go Deeper multiple times.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You stayed curious and kept leaning in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te mantuviste curioso y seguiste adentrándote."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciekawość prowadziła coraz dalej."
