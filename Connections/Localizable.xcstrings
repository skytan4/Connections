          "stringUnit": {
            "state": "translated",
            "value": "Cada pergunta vem acompanhada de dois desdobramentos para ajudar a conversa a ir mais fundo de forma natural"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bij elke vraag horen twee verdiepende vervolgvragen om het gesprek op gang te houden"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各質問には2つの掘り下げがあり、会話が自然に深まる"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni domanda include due approfondimenti per aiutare la conversazione ad andare naturalmente più in profondità"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varje fråga har två följdfrågor för att hjälpa samtalet att gå djupare naturligt"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvert spørgsmål har to opfølgningsspørgsmål, der hjælper samtalen til at gå dybere på naturlig vis"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvert spørsmål kommer med to oppfølgere for å hjelpe samtalen å gå dypere naturlig"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jokainen kysymys sisältää kaksi jatkokysymystä, jotka auttavat keskustelua syvenemään luontevasti"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个问题配有两个追问，帮助对话自然地深入"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "К каждому вопросу два уточняющих, которые помогают беседе идти глубже"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet3": {
      "comment": "Third bullet point in the How It Works sheet about saved progress.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your progress is saved, so you can pause and return across multiple sittings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso se guarda, para que puedas pausar y regresar en múltiples sesiones"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Postęp jest zapisywany, więc możesz zrobić przerwę i wrócić przy kolejnym spotkaniu"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt wird gespeichert, damit du pausieren und zu einem anderen Zeitpunkt weitermachen kannst"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre progression est sauvegardée, pour pouvoir faire des pauses et reprendre en plusieurs fois"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O seu progresso é salvo, para que possa pausar e retomar em diferentes momentos"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je voortgang wordt opgeslagen, zodat je kunt pauzeren en later verdergaan"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行状況が保存されるので、複数回に分けて続けられる"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi progressi vengono salvati, così puoi fare pause e riprendere in più momenti"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditt framsteg sparas, så du kan pausa och återvända vid flera tillfällen"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din fremgang gemmes, så du kan holde pause og vende tilbage på tværs af flere siddinger"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fremdriften din lagres, slik at du kan pause og returnere over flere sesjoner"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Edistymisesi tallentuu, joten voit pitää tauon ja jatkaa myöhemmillä istunnoilla"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "进度会自动保存，你可以分多次完成"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогресс сохраняется автоматически, можно возвращаться в любое время"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet4": {
      "comment": "Fourth bullet point in the How It Works sheet about the read-aloud format.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Designed to be read aloud — one person asks, the other tells their story"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado para leerse en voz alta — una persona pregunta, la otra cuenta su historia"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeznaczone do czytania na głos — jedna osoba pyta, druga opowiada swoją historię"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Vorlesen gedacht — eine Person fragt, die andere erzählt ihre Geschichte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu pour être lu à voix haute — une personne pose les questions, l'autre raconte son histoire"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pensado para ser lido em voz alta — uma pessoa pergunta, a outra conta sua história"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedoeld om hardop te lezen — één persoon vraagt, de ander vertelt"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "声に出して読むように設計されている――一人が聞き、もう一人がその物語を語る"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pensato per essere letto ad alta voce — una persona chiede, l'altra racconta la sua storia"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Utformad för att läsas högt – en person frågar, den andra berättar sin historia"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Designet til at blive læst højt — én person spørger, den anden fortæller sin historie"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Designet for å leses høyt – én person spør, den andre forteller sin historie"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suunniteltu luettavaksi ääneen – yksi kysyy, toinen kertoo tarinansa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设计为大声朗读——一个人提问，另一个人讲述他们的故事"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предназначено для чтения вслух — один задаёт вопросы, другой рассказывает свою историю"
          }
        }
      }
    },
