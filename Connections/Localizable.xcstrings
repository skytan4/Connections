    "sessionSetup.ageAlert.message": {
      "comment": "Body text of the age confirmation alert for the Sex topic.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sex prompts contain mature content. Please confirm you are 18 years or older to continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las preguntas sobre sexo contienen contenido para adultos. Confirma que tienes 18 años o más para continuar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pytania o seks zawierają treści dla dorosłych. Potwierdź, że masz 18 lat lub więcej, żeby kontynuować."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fragen zu diesem Thema enthalten explizite Inhalte. Bitte bestätige, dass du 18 Jahre oder älter bist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les invites sur la sexualité contiennent du contenu destiné aux adultes. Veuillez confirmer que vous avez 18 ans ou plus pour continuer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As perguntas sobre sexo contêm conteúdo adulto. Confirme que você tem 18 anos ou mais para continuar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Seks-vragen bevatten content voor volwassenen. Bevestig dat je 18 jaar of ouder bent om door te gaan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セックスに関するプロンプトには成人向けコンテンツが含まれます。18歳以上であることを確認してください。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I prompt sul sesso contengono contenuti per adulti. Conferma di avere 18 anni o più per continuare."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sexfrågor innehåller moget innehåll. Bekräfta att du är 18 år eller äldre för att fortsätta."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sex-prompts indeholder modent indhold. Bekræft venligst, at du er 18 år eller ældre for at fortsætte."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sex-spørsmål inneholder modent innhold. Bekreft at du er 18 år eller eldre for å fortsette."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Seksi-kehotteet sisältävät aikuisille tarkoitettua sisältöä. Vahvista, että olet 18-vuotias tai vanhempi jatkaaksesi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "性话题包含成人内容。请确认你已年满18岁再继续。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тема об интимности содержит контент для взрослых. Подтверди, что тебе исполнилось 18 лет, прежде чем продолжить."
          }
        }
      }
    },
