    "connectionLevel.openingUp.message": {
      "comment": "Summary message shown when users reach the Opening Up level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You opened up more as you went."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te fuiste abriendo más a medida que avanzabas."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Z każdą chwilą otwierało się coraz bardziej."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast dich mehr und mehr geöffnet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ouverture s'est installée peu à peu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você foi se abrindo cada vez mais."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je opende je meer naarmate je verder ging."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話すほどに、心が開いていった。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi siete aperti sempre di più andando avanti."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du öppnade dig mer allteftersom."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du åbnede dig mere op undervejs."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du åpnet deg mer etter hvert."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avauduit enemmän matkan varrella."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随着对话推进，你们打开了更多心扉。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "По мере беседы вы становились всё открытее."
          }
        }
      }
    },
