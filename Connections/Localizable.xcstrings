    "settings.language.appLanguage.accessibilityHint": {
      "comment": "Accessibility hint for the App Language row.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens this app’s settings in iOS Settings."
          }
        },
