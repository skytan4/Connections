    "recommendation.explanation.adjacentTopic": {
      "comment": "Recommendation explanation when user explored a specific topic and an adjacent one is suggested. Arg 1: the topic they stayed with (e.g. 'Communication'). Arg 2: the adjacent topic being recommended (e.g. 'Emotions').",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You stayed with prompts about %1$@. %2$@ might be worth exploring next."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te quedaste con preguntas sobre %1$@. Vale la pena explorar %2$@ a continuación."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pytania o %1$@ wciągnęły najbardziej. Warto zajrzeć w %2$@."
