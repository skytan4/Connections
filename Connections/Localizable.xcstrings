        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W swoim czasie tryb %1$@ ma więcej do zaoferowania."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du bereit bist, hat der %1$@-Modus mehr zu bieten."
          }
        },
        "fr": {
