    "lifeStoryIntro.howSheet.bullet1": {
      "comment": "First bullet point in the How It Works sheet describing question count and chapters.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "50 questions organized across 9 life chapters — from childhood to legacy"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "50 preguntas organizadas en 9 capítulos de vida — desde la infancia hasta el legado"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "50 pytań ułożonych w 9 rozdziałach życia — od dzieciństwa po dziedzictwo"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet2": {
      "comment": "Second bullet point in the How It Works sheet about follow-up questions.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each question comes with two follow-ups to help the conversation go deeper naturally"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada pregunta incluye dos seguimientos para ayudar a que la conversación fluya más profundamente de manera natural"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każde pytanie ma dwa pytania uzupełniające, które pomagają rozmowie pójść głębiej"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet3": {
      "comment": "Third bullet point in the How It Works sheet about saved progress.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your progress is saved, so you can pause and return across multiple sittings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso se guarda, para que puedas pausar y regresar en múltiples sesiones"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Postęp jest zapisywany, więc możesz zrobić przerwę i wrócić przy kolejnym spotkaniu"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.bullet4": {
      "comment": "Fourth bullet point in the How It Works sheet about the read-aloud format.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Designed to be read aloud — one person asks, the other tells their story"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado para leerse en voz alta — una persona pregunta, la otra cuenta su historia"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeznaczone do czytania na głos — jedna osoba pyta, druga opowiada swoją historię"
          }
        }
      }
    },
    "lifeStoryIntro.howSheet.button.gotIt": {
