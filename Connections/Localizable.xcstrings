    "sessionPlay.recommendation.prompt.intensityOnly": {
      "comment": "Recommendation teaser when no specific topic is recommended. Arg 1: localized intensity name (e.g. 'Honest').",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on how this session unfolded, we think a %1$@ session could be a good next step. Shall we start it for you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Basándonos en cómo se desarrolló esta sesión, creemos que una sesión %1$@ podría ser un buen siguiente paso. ¿La iniciamos?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na podstawie przebiegu tej sesji myślimy, że sesja w trybie %1$@ mogłaby być dobrym kolejnym krokiem. Mamy ją dla ciebie uruchomić?"
          }
        }
      }
    },
    "sessionPlay.recommendation.prompt.topicAndIntensity": {
