    "fallInLovePlay.complete.body.couples": {
      "comment": "Italic body text on the completion screen shown to couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a moment to appreciate the connection you've built."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toma un momento para apreciar la conexión que han construido."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Znajdź chwilę, by docenić więź, którą zbudowaliście."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimm dir einen Moment, um die Verbindung zu schätzen, die ihr aufgebaut habt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez un moment pour apprécier la connexion que vous avez construite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reserve um momento para valorizar a conexão que vocês construíram."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Neem even de tijd om de verbinding die jullie hebben opgebouwd te waarderen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ふたりで築いてきたつながりを、ひと息ついて感じてみて。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prendetevi un momento per apprezzare il legame che avete costruito."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta ett ögonblick att uppskatta kontakten ni har byggt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tag et øjeblik til at sætte pris på den forbindelse, I har bygget."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta et øyeblikk for å sette pris på forbindelsen dere har bygget."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ota hetki arvostaaksesi rakentamaanne yhteyttä."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "花一刻时间，感受你们之间建立的连接。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уделите минуту, чтобы почувствовать связь, которую вы создали."
          }
        }
      }
    },
