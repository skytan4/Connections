            "value": "In base a come si è svolta questa sessione, pensiamo che una sessione su %1$@ al livello %2$@ potrebbe essere un buon passo successivo. Vuoi che la avviamo per te?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
