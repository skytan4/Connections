    },
    "settings.session.questionCount.label": {
      "comment": "Label above the default session length picker in Settings > Session.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Default question count"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
