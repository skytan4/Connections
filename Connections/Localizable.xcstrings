          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur le cœur d'une question pour la sauvegarder ici."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque no coração em qualquer pergunta para salvá-la aqui para depois."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op het hartje bij een vraag om die hier op te slaan voor later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "気に入ったプロンプトのハートをタップして、あとで見返せるように保存しよう。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca il cuore su qualsiasi domanda per salvarla qui per dopo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck på hjärtat på en fråga för att spara den här till senare."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk på hjertet på en prompt for at gemme den her til senere."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk på hjertet på en hvilken som helst spørsmålskort for å lagre det her til senere."
