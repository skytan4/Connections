    "connectionLevel.deeplyConnected.message": {
      "comment": "Summary message shown when users reach the Deeply Connected level.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You reached a deeper level tonight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegaron a un nivel más profundo esta noche."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dziś rozmowa sięgnęła głębszego poziomu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast heute Abend eine tiefere Ebene erreicht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelque chose de plus profond a émergé ce soir."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocês chegaram a um nível mais profundo esta noite."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt vanavond een dieper niveau bereikt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今夜、もっと深いところに届いた。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stasera avete raggiunto un livello più profondo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni nådde en djupare nivå ikväll."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "I nåede et dybere niveau i aften."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dere nådde et dypere nivå i kveld."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saavutit tänä iltana syvemmän tason."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今晚你们触及了更深的层面。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этим вечером вы прикоснулись к чему-то глубокому."
          }
        }
      }
    },
