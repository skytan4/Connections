    "onboarding.page1.body": {
      "comment": "Body text for onboarding page 1.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations stay on the surface.\nThis helps you get to something more real."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunas conversaciones se quedan en la superficie.\nEsto te ayuda a llegar a algo más real."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niektóre rozmowy pozostają na powierzchni.\nTo pomaga dotrzeć do czegoś bardziej prawdziwego."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manche Gespräche bleiben an der Oberfläche.\nHier kommst du zu etwas Echterem."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certaines conversations restent en surface.\nCeci vous aide à accéder à quelque chose de plus authentique."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algumas conversas ficam na superfície.\nIsso ajuda você a chegar a algo mais real."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sommige gesprekken blijven aan de oppervlakte.\nDit helpt je tot iets echters te komen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表面だけで終わる会話もある。\nこのアプリは、もっとリアルな場所へ連れて行く。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Certe conversazioni restano in superficie.\nQuesta ti aiuta ad arrivare a qualcosa di più reale."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En del samtal stannar på ytan.\nDet här hjälper dig att nå något mer verkligt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Nogle samtaler forbliver på overfladen.\nDette hjælper dig med at komme til noget mere virkeligt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Noen samtaler holder seg på overflaten.\nDette hjelper deg å komme til noe mer ekte."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jotkut keskustelut pysyvät pinnalla.\nTämä auttaa sinua pääsemään johonkin todellisempaan."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有些对话总是停留在表面。\n这个应用帮助你走向更真实的交流。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые разговоры так и остаются поверхностными.\nЭто приложение помогает выйти на более настоящий уровень."
          }
        }
      }
    },
    "onboarding.page1.title": {
      "comment": "Title for onboarding page 1.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go beyond small talk"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve más allá de las charlas triviales"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyjdź poza small talk"
          }
        },
        "de": {
