    "lifeStoryIntro.howSheet.footer": {
      "comment": "Closing remark below the bullet points in the How It Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations only happen\nwhen someone knows to ask."
          }
