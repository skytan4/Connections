    "shareExperience.about.footer": {
      "comment": "Closing remark below the bullet points in the About this mode sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This isn't small talk.\nTreat it like it matters, and it will."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto no es charla superficial.\nTrátalo como si importara, y lo hará."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To nie jest small talk.\nTraktuj to poważnie, a ma znaczenie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das ist kein Smalltalk.\nNimm es ernst — dann wird es das auch sein."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce n'est pas de la conversation banale.\nTraitez-la comme si elle comptait, et elle comptera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso não é conversa fiada.\nTrate como algo que importa, e vai importar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit is geen smalltalk.\nBehandel het alsof het ertoe doet, en dat zal het."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは雑談じゃない。\n大切に扱えば、本当に大切なものになる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa non è una conversazione banale.\nTrattala come se importasse, e importerà."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här är inte småprat.\nBemöt det som om det spelar roll, och det kommer det att göra."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette er ikke small talk.\nBehandl det som om det betyder noget, og det vil det."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette er ikke løs prat.\nBehandl det som om det betyr noe, og det vil."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä ei ole pintakeskustelua.\nKohtelele sitä kuin sillä olisi merkitystä, ja niin onkin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这不是闲聊。\n认真对待，它就会有意义。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это не светская болтовня.\nОтнесись к этому серьёзно — и это будет иметь значение."
          }
        }
      }
    },
