    "fallInLoveIntro.body.couples": {
      "comment": "Body paragraph shown to couples on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not by chance — but through attention, honesty, and shared moments.\n\nA series of thoughtfully designed questions can deepen connection, spark curiosity, and bring you closer — one conversation at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No por casualidad — sino a través de la atención, la honestidad y los momentos compartidos.\n\nUna serie de preguntas cuidadosamente diseñadas puede profundizar la conexión, despertar la curiosidad y acercarlos — una conversación a la vez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie przez przypadek — przez uwagę, szczerość i wspólne chwile.\n\nSeria starannie opracowanych pytań może pogłębić więź, rozbudzić ciekawość i zbliżyć do siebie — jedna rozmowa na raz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht durch Zufall — sondern durch Aufmerksamkeit, Ehrlichkeit und gemeinsame Momente.\n\nDurchdacht gestaltete Fragen können die Verbindung vertiefen, Neugier wecken und euch einander näherbringen — ein Gespräch nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas par hasard — mais grâce à l'attention, l'honnêteté et les moments partagés.\n\nUne série de questions soigneusement conçues peut approfondir la connexion, éveiller la curiosité et vous rapprocher — une conversation à la fois."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não por acaso — mas pela atenção, honestidade e momentos compartilhados.\n\nUma série de perguntas cuidadosamente elaboradas pode aprofundar a conexão, despertar curiosidade e aproximar vocês — uma conversa de cada vez."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet door toeval — maar door aandacht, eerlijkheid en gedeelde momenten.\n\nDoordacht opgestelde vragen kunnen de verbinding verdiepen, nieuwsgierigheid aanwakkeren en jullie nader tot elkaar brengen — één gesprek tegelijk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "偶然じゃなく――気づき、正直さ、共に過ごした時間が積み重なって。\n\n丁寧に設計された質問が、つながりを深め、好奇心に火をつけ、少しずつ近づかせてくれる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non per caso — ma attraverso attenzione, onestà e momenti condivisi.\n\nUna serie di domande studiate con cura può approfondire il legame, accendere la curiosità e avvicinarvi — una conversazione alla volta."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inte av en slump – utan genom uppmärksamhet, ärlighet och delade ögonblick.\n\nEn serie genomtänkta frågor kan fördjupa kontakten, väcka nyfikenhet och föra er närmare – ett samtal i taget."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke ved et tilfælde — men gennem opmærksomhed, ærlighed og delte øjeblikke.\n\nEn serie af omhyggeligt udformede spørgsmål kan uddybe forbindelsen, vække nysgerrighed og bringe jer tættere på hinanden — én samtale ad gangen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke tilfeldig – men gjennom oppmerksomhet, ærlighet og felles øyeblikk.\n\nEn serie nøye utformede spørsmål kan fordype forbindelsen, vekke nysgjerrighet og bringe dere nærmere – én samtale om gangen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei sattumalta – vaan huomion, rehellisyyden ja yhteisten hetkien kautta.\n\nHuolellisesti suunnitellut kysymykset voivat syventää yhteyttä, herättää uteliaisuutta ja tuoda teitä lähemmäksi – yksi keskustelu kerrallaan."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不是靠运气——而是靠用心、真诚和共同的时刻。\n\n一系列精心设计的问题，能够加深连接、激发好奇心，让你们一次又一次的对话中越走越近。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это не случайность — это внимание, честность и совместные моменты.\n\nСерия специально подобранных вопросов, которые углубляют связь, пробуждают любопытство и сближают вас с каждым новым разговором."
          }
        }
      }
    },
    "fallInLoveIntro.body.friends": {
      "comment": "Body paragraph shown to friends on the Fall in Love intro screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations create clarity, trust, and unexpected connection.\n\nThese questions are designed to help two people move past surface-level talk and into something more honest, open, and real."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunas conversaciones crean claridad, confianza y conexión inesperada.\n\nEstas preguntas están diseñadas para ayudar a dos personas a ir más allá de la charla superficial y llegar a algo más honesto, abierto y real."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niektóre rozmowy budują jasność, zaufanie i niespodziewaną więź.\n\nTe pytania mają pomóc dwóm osobom wyjść poza powierzchowną rozmowę i wejść w coś bardziej szczerego, otwartego i prawdziwego."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manche Gespräche schaffen Klarheit, Vertrauen und unerwartete Nähe.\n\nDiese Fragen helfen zwei Menschen, über oberflächlichen Smalltalk hinauszugehen — hin zu etwas Ehrlichem, Offenem und Echtem."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certaines conversations créent de la clarté, de la confiance et une connexion inattendue.\n\nCes questions sont conçues pour aider deux personnes à dépasser les échanges en surface et aller vers quelque chose de plus honnête, ouvert et réel."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algumas conversas trazem clareza, confiança e uma conexão inesperada.\n\nEssas perguntas foram criadas para ajudar duas pessoas a ir além do superficial e chegar a algo mais honesto, aberto e verdadeiro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sommige gesprekken brengen helderheid, vertrouwen en onverwachte verbinding.\n\nDeze vragen helpen twee mensen voorbij oppervlakkige praatjes te gaan — naar iets eerlijker, opener en echter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "会話には、心が整い、信頼が生まれ、思いがけないつながりをもたらすものがある。\n\nこの質問たちは、表面的な話を超えて、もっと正直で、開かれた、本物の場所へ進む手助けをしてくれる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alcune conversazioni creano chiarezza, fiducia e connessione inaspettata.\n\nQueste domande sono pensate per aiutare due persone ad andare oltre le chiacchiere di superficie e arrivare a qualcosa di più onesto, aperto e vero."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En del samtal skapar klarhet, förtroende och oväntad kontakt.\n\nDessa frågor är utformade för att hjälpa två personer att gå bortom ytliga samtal och in i något mer ärligt, öppet och verkligt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Nogle samtaler skaber klarhed, tillid og uventet forbindelse.\n\nDisse spørgsmål er designet til at hjælpe to mennesker med at komme forbi overfladisk snak og ind i noget mere ærligt, åbent og virkeligt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Noen samtaler skaper klarhet, tillit og uventet nærhet.\n\nDisse spørsmålene er laget for å hjelpe to mennesker å gå forbi overfladisk prat og inn i noe mer ærlig, åpent og ekte."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jotkut keskustelut luovat selkeyttä, luottamusta ja odottamatonta yhteyttä.\n\nNämä kysymykset on suunniteltu auttamaan kahta ihmistä siirtymään pintapuolisesta jutustelusta kohti jotain rehellisempää, avoimempaa ja todellisempaa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有些对话能带来清晰、信任和意想不到的连接。\n\n这些问题旨在帮助两个人跨越表面的寒暄，走向更真诚、更开放、更真实的交流。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Некоторые разговоры приносят ясность, доверие и неожиданную близость.\n\nЭти вопросы помогают двум людям выйти за рамки светских бесед и прийти к более честному, открытому и настоящему общению."
          }
        }
      }
    },
