    "paywall.general.body": {
      "comment": "Body text on the general paywall screen explaining what the full unlock includes.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get deeper prompts, longer conversations, and guided experiences designed for the moments that matter most."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtén preguntas más profundas, conversaciones más largas y experiencias guiadas diseñadas para los momentos que más importan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzyskaj głębsze pytania, dłuższe rozmowy i prowadzone doświadczenia zaprojektowane na chwile, które mają największe znaczenie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiefere Fragen, längere Gespräche und geführte Erlebnisse – für die Momente, die wirklich zählen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez à des questions plus profondes, des conversations plus longues et des expériences guidées conçues pour les moments qui comptent vraiment."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenha perguntas mais profundas, conversas mais longas e experiências guiadas criadas para os momentos que mais importam."
          }
        }
      }
    },
