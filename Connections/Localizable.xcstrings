            "state": "translated",
            "value": "Über Small Talk hinaus"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aller au-delà des banalités"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vá além das conversas superficiais"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verder dan smalltalk"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "雑談を超えていく"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai oltre le chiacchiere superficiali"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Gå bortom småprat"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kom ud over small talk"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gå forbi løs prat"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mene pintakeskustelua syvemmälle"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "超越寒暄"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глубже светской беседы"
          }
        }
      }
    },
    "onboarding.page2.body": {
      "comment": "Body text for onboarding page 2.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thoughtful prompts help people slow down, open up, and understand each other more honestly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las preguntas reflexivas ayudan a las personas a ir más despacio, abrirse y entenderse mutuamente con más honestidad."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przemyślane pytania pomagają ludziom zwolnić, otworzyć się i lepiej siebie nawzajem zrozumieć."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchdachte Fragen helfen, innezuhalten, sich zu öffnen und sich ehrlicher zu verstehen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des questions réfléchies aident les gens à ralentir, à s'ouvrir et à mieux se comprendre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Perguntas bem pensadas ajudam as pessoas a desacelerar, se abrir e se entender com mais honestidade."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Doordachte vragen helpen mensen te vertragen, zich te openen en elkaar eerlijker te begrijpen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "丁寧なプロンプトが、立ち止まり、心を開き、お互いをより深く知るきっかけになる。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Domande ponderate aiutano le persone a rallentare, aprirsi e capirsi con più onestà."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genomtänkta frågor hjälper människor att sakta ner, öppna sig och förstå varandra mer ärligt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gennemtænkte prompts hjælper folk med at sænke tempoet, åbne sig og forstå hinanden mere ærligt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjennomtenkte spørsmål hjelper folk å senke tempoet, åpne seg og forstå hverandre mer ærlig."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Harkitut kehotteet auttavat ihmisiä hidastamaan, avautumaan ja ymmärtämään toisiaan rehellisemmin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "精心设计的提示帮助人们慢下来、敞开心扉，更真诚地理解彼此。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продуманные вопросы помогают людям замедлиться, открыться и понять друг друга по-настоящему."
          }
        }
      }
    },
