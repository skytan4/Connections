    "paywall.lifeStory.body": {
      "comment": "Body text on the Life Story paywall screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A guided experience for asking parents, grandparents, or older relatives meaningful questions about their stories, memories, and legacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una experiencia guiada para hacer a padres, abuelos o familiares mayores preguntas significativas sobre sus historias, recuerdos y legado."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prowadzone doświadczenie — pytania do rodziców, dziadków lub starszych bliskich o ich historię, wspomnienia i dziedzictwo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein geführtes Erlebnis, um Eltern, Großeltern oder älteren Verwandten bedeutungsvolle Fragen über ihre Geschichten, Erinnerungen und ihr Vermächtnis zu stellen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une expérience guidée pour poser aux parents, grands-parents ou proches plus âgés des questions sincères sur leurs histoires, leurs souvenirs et leur héritage."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma experiência guiada para fazer perguntas significativas a pais, avós ou familiares mais velhos sobre suas histórias, memórias e legado."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een begeleide ervaring voor het stellen van betekenisvolle vragen aan ouders, grootouders of oudere familieleden over hun verhalen, herinneringen en nalatenschap."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "親、祖父母、年上の親族に、その物語・思い出・受け継ぐものについて意味のある質問をするためのガイド付き体験。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un'esperienza guidata per porre a genitori, nonni o parenti anziani domande significative sulle loro storie, ricordi ed eredità."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En guidad upplevelse för att ställa föräldrar, far- och morföräldrar eller äldre släktingar meningsfulla frågor om deras historier, minnen och arv."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En guidet oplevelse til at stille forældre, bedsteforældre eller ældre slægtninge meningsfulde spørgsmål om deres historier, minder og arv."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En veiledet opplevelse for å stille foreldre, besteforeldre eller eldre slektninger meningsfulle spørsmål om historiene, minnene og arven deres."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohjattu kokemus vanhemmille, isovanhemmille tai vanhemmille sukulaisille esitettäviä merkityksellisiä kysymyksiä varten heidän tarinoistaan, muistoistaan ja perinnöstään."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一场引导式体验，帮助你向父母、祖父母或年长的亲人提出关于他们故事、回忆和传承的有意义的问题。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Направляемый опыт, который помогает задавать родителям, бабушкам и дедушкам или пожилым близким значимые вопросы об их истории, воспоминаниях и наследии."
          }
        }
      }
    },
