    "onboarding.page1.body": {
      "comment": "Body text for onboarding page 1.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some conversations stay on the surface.\nThis helps you get to something more real."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunas conversaciones se quedan en la superficie.\nEsto te ayuda a llegar a algo más real."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niektóre rozmowy pozostają na powierzchni.\nTo pomaga dotrzeć do czegoś bardziej prawdziwego."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manche Gespräche bleiben an der Oberfläche.\nHier kommst du zu etwas Echterem."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certaines conversations restent en surface.\nCeci vous aide à accéder à quelque chose de plus authentique."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algumas conversas ficam na superfície.\nIsso ajuda você a chegar a algo mais real."
          }
        }
      }
    },
    "onboarding.page1.title": {
      "comment": "Title for onboarding page 1.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go beyond small talk"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve más allá de las charlas triviales"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyjdź poza small talk"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Über Small Talk hinaus"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aller au-delà des banalités"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vá além das conversas superficiais"
          }
        }
      }
    },
    "onboarding.page2.body": {
      "comment": "Body text for onboarding page 2.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thoughtful prompts help people slow down, open up, and understand each other more honestly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las preguntas reflexivas ayudan a las personas a ir más despacio, abrirse y entenderse mutuamente con más honestidad."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przemyślane pytania pomagają ludziom zwolnić, otworzyć się i lepiej siebie nawzajem zrozumieć."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchdachte Fragen helfen, innezuhalten, sich zu öffnen und sich ehrlicher zu verstehen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des questions réfléchies aident les gens à ralentir, à s'ouvrir et à mieux se comprendre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Perguntas bem pensadas ajudam as pessoas a desacelerar, se abrir e se entender com mais honestidade."
          }
        }
      }
    },
    "onboarding.page2.title": {
      "comment": "Title for onboarding page 2.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built for connection"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construido para la conexión"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stworzone dla więzi"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für echte Verbindung"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu pour la connexion"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Feito para a conexão"
          }
        }
      }
    },
    "onboarding.page3.body": {
      "comment": "Body text for onboarding page 3.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With a partner, a friend, your family, or just yourself.\nThere's no perfect way to begin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con una pareja, un amigo, tu familia, o contigo mismo.\nNo hay una forma perfecta de comenzar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Z partnerem, przyjacielem, rodziną lub w pojedynkę.\nNie ma idealnego sposobu, żeby zacząć."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit jemandem an deiner Seite, einem Freund, deiner Familie – oder allein.\nEs gibt keinen perfekten Anfang."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avec un partenaire, un ami, votre famille, ou simplement vous-même.\nIl n'y a pas de façon parfaite de commencer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com um parceiro, um amigo, sua família ou apenas você.\nNão existe uma forma perfeita de começar."
          }
        }
      }
    },
    "onboarding.page3.title": {
      "comment": "Title for onboarding page 3.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start where you are"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comienza donde estás"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacznij tam, gdzie jesteś"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fang dort an, wo du bist"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencer là où vous en êtes"
          }
        },
