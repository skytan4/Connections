        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compris"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendi"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet1": {
      "comment": "First bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When two people take turns answering honest questions, they naturally match each other's openness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando dos personas se turnan para responder preguntas honestas, naturalmente igualan la apertura del otro"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiedy dwie osoby na zmianę odpowiadają na szczere pytania, naturalnie dopasowują poziom swojej otwartości"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn zwei Menschen sich abwechselnd ehrlichen Fragen stellen, öffnen sie sich ganz natürlich füreinander"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand deux personnes répondent à tour de rôle à des questions sincères, elles s'accordent naturellement sur le degré d'ouverture"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando duas pessoas se revezam respondendo perguntas sinceras, naturalmente correspondem à abertura uma da outra"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feeling genuinely listened to — not just heard — is one of the strongest drivers of closeness"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentirse genuinamente escuchado — no solo oído — es uno de los factores más poderosos para generar cercanía"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poczucie, że ktoś naprawdę słucha — nie tylko słyszy — jest jednym z najsilniejszych czynników budujących bliskość"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wirklich gehört zu werden — nicht nur wahrgenommen — ist einer der stärksten Treiber von Nähe"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se sentir vraiment écouté — pas seulement entendu — est l'un des moteurs les plus puissants de la proximité"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentir-se genuinamente ouvido — não apenas escutado — é um dos maiores impulsionadores da proximidade"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vulnerability doesn't just build trust. It signals that trust already exists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnerabilidad no solo construye confianza. Señala que la confianza ya existe."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wrażliwość nie tylko buduje zaufanie. Sygnalizuje, że zaufanie już istnieje."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verletzlichkeit schafft nicht nur Vertrauen. Sie zeigt, dass dieses Vertrauen bereits da ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vulnérabilité ne fait pas que construire la confiance. Elle signale que cette confiance existe déjà."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A vulnerabilidade não apenas constrói confiança. Ela sinaliza que a confiança já existe."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The conversations that deepen a relationship are rarely dramatic. They're the ones where someone feels met."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las conversaciones que profundizan una relación rara vez son dramáticas. Son aquellas en las que alguien se siente visto."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozmowy, które pogłębiają związek, rzadko są dramatyczne. To te, w których ktoś poczuł się naprawdę zrozumiany."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Gespräche, die eine Beziehung vertiefen, sind selten dramatisch. Es sind die Momente, in denen sich jemand wirklich gesehen fühlt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conversations qui approfondissent une relation sont rarement spectaculaires. Ce sont celles où quelqu'un se sent vraiment rejoint."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As conversas que aprofundam um relacionamento raramente são dramáticas. São aquelas em que alguém se sente verdadeiramente visto."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.couples.footer": {
      "comment": "Closing remark in the Why This Works sheet for couples.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't fall in love all at once.\nYou build it — one honest moment at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te enamoras de golpe.\nLo construyes — un momento honesto a la vez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zakochujesz się raz na zawsze.\nBudujesz to — jedna szczera chwila na raz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Man verliebt sich nicht auf einmal.\nMan baut es auf — einen ehrlichen Moment nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On ne tombe pas amoureux d'un coup.\nÇa se construit — un moment honnête à la fois."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não nos apaixonamos de uma vez só.\nConstruímos isso — um momento honesto de cada vez."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet1": {
      "comment": "First bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When one person shares something real, others tend to match that openness — without being asked"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando una persona comparte algo real, los demás tienden a igualar esa apertura — sin que se les pida"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiedy jedna osoba dzieli się czymś prawdziwym, inne zazwyczaj dopasowują tę otwartość — bez pytania"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn eine Person etwas Echtes teilt, öffnen sich andere ganz von selbst — ohne dass man sie darum bitten müsste"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand quelqu'un partage quelque chose de vrai, les autres ont tendance à suivre cette ouverture — sans qu'on le demande"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando alguém compartilha algo verdadeiro, os outros tendem a corresponder essa abertura — sem precisar ser pedido"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet2": {
      "comment": "Second bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Asking a genuine question and actually listening is one of the simplest ways to deepen a friendship"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacer una pregunta genuina y escuchar de verdad es una de las formas más simples de profundizar una amistad"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadanie szczerego pytania i prawdziwe słuchanie to jeden z najprostszych sposobów na pogłębienie przyjaźni"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine aufrichtige Frage stellen und wirklich zuhören ist einer der einfachsten Wege, eine Freundschaft zu vertiefen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poser une vraie question et écouter réellement est l'une des façons les plus simples d'approfondir une amitié"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazer uma pergunta genuína e realmente escutar é uma das formas mais simples de aprofundar uma amizade"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet3": {
      "comment": "Third bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trust grows in small moments — when someone feels heard, not just talked to"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La confianza crece en pequeños momentos — cuando alguien se siente escuchado, no solo hablado"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaufanie rośnie w małych chwilach — gdy ktoś czuje się wysłuchany, a nie tylko wysłuchiwany"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertrauen wächst in kleinen Momenten — wenn jemand das Gefühl hat, gehört zu werden, nicht nur bespielt zu werden"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La confiance grandit dans les petits moments — quand quelqu'un se sent écouté, pas seulement interpellé"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A confiança cresce em pequenos momentos — quando alguém se sente ouvido, não apenas falado"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.bullet4": {
      "comment": "Fourth bullet in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most friendships stay at the surface not because people don't care, but because no one goes first"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La mayoría de las amistades se quedan en la superficie no porque no les importe, sino porque nadie da el primer paso"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Większość przyjaźni pozostaje na powierzchni nie dlatego, że ludziom nie zależy, ale dlatego, że nikt nie zaczyna pierwszy"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die meisten Freundschaften bleiben an der Oberfläche — nicht weil es niemanden interessiert, sondern weil niemand den ersten Schritt macht"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La plupart des amitiés restent en surface non pas parce que les gens ne tiennent pas les uns aux autres, mais parce que personne ne fait le premier pas"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A maioria das amizades fica na superfície não porque as pessoas não se importam, mas porque ninguém dá o primeiro passo"
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.friends.footer": {
      "comment": "Closing remark in the Why This Works sheet for friends.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The deepest friendships aren't found.\nThey're built — one real conversation at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las amistades más profundas no se encuentran.\nSe construyen — una conversación real a la vez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najgłębszych przyjaźni się nie znajduje.\nBuduje się je — jedna prawdziwa rozmowa na raz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die tiefsten Freundschaften findet man nicht.\nMan baut sie — ein echtes Gespräch nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les amitiés les plus profondes ne se trouvent pas.\nElles se construisent — une vraie conversation à la fois."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As amizades mais profundas não são encontradas.\nSão construídas — uma conversa verdadeira de cada vez."
          }
        }
      }
    },
    "fallInLoveIntro.whySheet.title": {
      "comment": "Title heading rendered at the top of the Why This Works sheet.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Why this works"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por qué funciona"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dlaczego to działa"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "So funktioniert es"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pourquoi ça fonctionne"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por que isso funciona"
          }
        }
      }
    },
    "fallInLovePlay.alert.startOver.confirm": {
      "comment": "Destructive button in the Start Over confirmation alert that resets Fall in Love progress.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reiniciar"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Resetuj"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zurücksetzen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réinitialiser"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reiniciar"
          }
        }
      }
    },
    "fallInLovePlay.alert.startOver.message": {
      "comment": "Message body in the Start Over confirmation alert explaining what reset does.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will reset your progress back to Question 1. This is useful when starting with a new person."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reiniciará tu progreso a la Pregunta 1. Es útil cuando comienzas con una nueva persona."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to zresetowanie postępu do pytania 1. Przydatne przy rozmowie z nową osobą."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Damit wird dein Fortschritt auf Frage 1 zurückgesetzt. Das ist praktisch, wenn du mit einer neuen Person anfängst."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela remettra votre progression à la question 1. Utile pour commencer avec une nouvelle personne."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso vai reiniciar o seu progresso para a Pergunta 1. Útil quando for começar com uma nova pessoa."
          }
        }
      }
    },
    "fallInLovePlay.alert.startOver.title": {
      "comment": "Title of the Start Over confirmation alert in the Fall in Love play view.",
      "extractionState": "manual",
      "localizations": {
        "en": {
