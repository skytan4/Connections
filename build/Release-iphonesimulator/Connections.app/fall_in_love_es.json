{
  "schemaVersion": 1,
  "language": "es",
  "prompts": [
    {
      "id": "fil_01",
      "text": "Si pudieras invitar a cualquier persona del mundo a cenar, ¿quién sería?",
      "intensity": "honest",
      "depth": "warmUp",
      "order": 1
    },
    {
      "id": "fil_02",
      "text": "¿Te gustaría ser famoso? ¿De qué manera?",
      "intensity": "honest",
      "depth": "warmUp",
      "order": 2
    },
    {
      "id": "fil_03",
      "text": "Antes de hacer una llamada, ¿ensayas lo que vas a decir? ¿Por qué?",
      "intensity": "honest",
      "depth": "warmUp",
      "order": 3
    },
    {
      "id": "fil_04",
      "text": "¿Cómo sería un día perfecto para ti?",
      "intensity": "honest",
      "depth": "warmUp",
      "order": 4
    },
    {
      "id": "fil_05",
      "text": "¿Cuándo fue la última vez que cantaste para ti mismo o para alguien más?",
      "intensity": "honest",
      "depth": "warmUp",
      "order": 5
    },
    {
      "id": "fil_06",
      "text": "Si pudieras vivir hasta los 90 años y conservar tu mente o tu cuerpo joven, ¿cuál elegirías?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 6
    },
    {
      "id": "fil_07",
      "text": "¿Tienes alguna idea de cómo podrías morir?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 7
    },
    {
      "id": "fil_08",
      "text": "¿Cuáles son tres cosas que podríamos tener en común?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 8
    },
    {
      "id": "fil_09",
      "text": "¿Por qué estás más agradecido en este momento?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 9
    },
    {
      "id": "fil_10",
      "text": "Si pudieras cambiar algo de tu crianza, ¿qué sería?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 10
    },
    {
      "id": "fil_11",
      "text": "Cuenta tu historia de vida en unos minutos",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 11
    },
    {
      "id": "fil_12",
      "text": "Si pudieras despertar con una nueva habilidad, ¿cuál sería?",
      "intensity": "honest",
      "depth": "realTalk",
      "order": 12
    },
    {
      "id": "fil_13",
      "text": "Si pudieras conocer el futuro, ¿qué querrías saber?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 13
    },
    {
      "id": "fil_14",
      "text": "¿Qué es algo que siempre has querido hacer pero aún no has hecho?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 14
    },
    {
      "id": "fil_15",
      "text": "¿De qué logro te sientes más orgulloso?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 15
    },
    {
      "id": "fil_16",
      "text": "¿Qué es lo que más valoras en una amistad?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 16
    },
    {
      "id": "fil_17",
      "text": "¿Cuál es uno de tus recuerdos más significativos?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 17
    },
    {
      "id": "fil_18",
      "text": "¿Cuál es uno de tus recuerdos más difíciles?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 18
    },
    {
      "id": "fil_19",
      "text": "Si te quedara un año de vida, ¿cambiarías algo de cómo vives?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 19
    },
    {
      "id": "fil_20",
      "text": "¿Qué significa la amistad para ti?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 20
    },
    {
      "id": "fil_21",
      "text": "¿Qué papel juegan el amor y el afecto en tu vida?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 21
    },
    {
      "id": "fil_22",
      "text": "Comparte algo que aprecias de mí",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 22
    },
    {
      "id": "fil_23",
      "text": "¿Cómo era tu familia cuando crecías?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 23
    },
    {
      "id": "fil_24",
      "text": "¿Cómo te sientes con respecto a tu relación con tu mamá?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 24
    },
    {
      "id": "fil_25",
      "text": "Creen tres afirmaciones con 'nosotros' sobre los dos",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 25
    },
    {
      "id": "fil_26",
      "text": "Completa esto: Ojalá tuviera con quién compartir ____",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 26
    },
    {
      "id": "fil_27",
      "text": "¿Qué debería saber sobre ti si nos volviéramos cercanos?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 27
    },
    {
      "id": "fil_28",
      "text": "Dime algo que genuinamente aprecias de mí",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 28
    },
    {
      "id": "fil_29",
      "text": "Comparte un momento vergonzoso",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 29
    },
    {
      "id": "fil_30",
      "text": "¿Cuándo fue la última vez que lloraste frente a alguien o solo?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 30
    },
    {
      "id": "fil_31",
      "text": "Dime algo que ya te gusta de mí",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 31
    },
    {
      "id": "fil_32",
      "text": "¿Qué es demasiado serio para bromear al respecto?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 32
    },
    {
      "id": "fil_33",
      "text": "¿Qué lamentarías no haber dicho si murieras esta noche?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 33
    },
    {
      "id": "fil_34",
      "text": "¿Qué salvarías de un incendio y por qué?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 34
    },
    {
      "id": "fil_35",
      "text": "¿La muerte de quién te afectaría más y por qué?",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 35
    },
    {
      "id": "fil_36",
      "text": "Comparte un problema personal y deja que tu pareja repita lo que escuchó",
      "intensity": "unfiltered",
      "depth": "deepDive",
      "order": 36
    }
  ]
}
